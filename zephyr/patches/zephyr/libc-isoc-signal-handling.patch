diff --git a/lib/libc/common/source/signal/raise.c b/lib/libc/common/source/signal/raise.c
new file mode 100644
index 00000000000..bed2a3ac615
--- /dev/null
+++ b/lib/libc/common/source/signal/raise.c
@@ -0,0 +1,36 @@
+/*
+ * SPDX-License-Identifier: Apache-2.0
+ * SPDX-FileCopyrightText: Copyright The Zephyr Project Contributors
+ */
+
+#include "sig_isoc.h"
+
+#include <errno.h>
+#include <signal.h>
+
+#include <zephyr/kernel.h>
+#include <zephyr/kernel/signal.h>
+
+int raise(int sig)
+{
+	int ret;
+	int ksig;
+
+	ksig = (z_sig_from_posix != NULL) ? z_sig_from_posix(sig) : z_isoc_sig_to_k(sig);
+	if (ksig <= 0) {
+		errno = EINVAL;
+		return -1;
+	}
+
+	/*
+	 * ISO C requires the handler to have finished before raise() returns; the generated
+	 * k_sig_queue() wrapper drains pending signals before returning here.
+	 */
+	ret = k_sig_queue(k_current_get(), ksig, (union k_sig_val){0});
+	if (ret < 0) {
+		errno = -ret;
+		return -1;
+	}
+
+	return 0;
+}
diff --git a/lib/libc/common/source/signal/sig_isoc.h b/lib/libc/common/source/signal/sig_isoc.h
new file mode 100644
index 00000000000..9bf24b8ed8d
--- /dev/null
+++ b/lib/libc/common/source/signal/sig_isoc.h
@@ -0,0 +1,66 @@
+/*
+ * SPDX-FileCopyrightText: Copyright The Zephyr Project Contributors
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#ifndef ZEPHYR_LIB_LIBC_COMMON_SOURCE_SIGNAL_SIG_ISOC_H_
+#define ZEPHYR_LIB_LIBC_COMMON_SOURCE_SIGNAL_SIG_ISOC_H_
+
+#include <signal.h>
+
+#include <zephyr/kernel.h>
+#include <zephyr/kernel/signal.h>
+#include <zephyr/toolchain.h>
+
+/*
+ * The ISO C dispositions must be representable as kernel dispositions, since signal() hands
+ * them straight to k_sig_action() and hands k_sig_action()'s output straight back to the caller.
+ */
+BUILD_ASSERT((void *)SIG_DFL == K_SIG_DFL, "SIG_DFL does not match K_SIG_DFL");
+BUILD_ASSERT((void *)SIG_IGN == K_SIG_IGN, "SIG_IGN does not match K_SIG_IGN");
+BUILD_ASSERT((void *)SIG_ERR == K_SIG_ERR, "SIG_ERR does not match K_SIG_ERR");
+
+/**
+ * @brief Convert a C library signal number to a kernel signal number
+ *
+ * Only the six signals required by ISO C are translated. A C library is free to number signals
+ * however it likes, and the ones Zephyr ships with disagree: picolibc and newlib inherit Cygwin's
+ * numbering, where SIGUSR1 is 30, while the kernel and the POSIX option group follow Linux, where
+ * it is 10. Translating the rest needs the full table that the POSIX signals option group owns,
+ * so signal() defers to it by being weak, and raise() picks the full table up through a weak
+ * reference to z_sig_from_posix() when the POSIX layer is linked.
+ *
+ * @param sig C library signal number
+ * @return the corresponding kernel signal number, or -1 if @p sig is not an ISO C signal number
+ */
+static inline int z_isoc_sig_to_k(int sig)
+{
+	switch (sig) {
+	case SIGABRT:
+		return K_SIG_ABRT;
+	case SIGFPE:
+		return K_SIG_FPE;
+	case SIGILL:
+		return K_SIG_ILL;
+	case SIGINT:
+		return K_SIG_INT;
+	case SIGSEGV:
+		return K_SIG_SEGV;
+	case SIGTERM:
+		return K_SIG_TERM;
+	default:
+		return -1;
+	}
+}
+
+/*
+ * Provided by the POSIX signals option group when it is linked; resolve to NULL otherwise.
+ * z_sig_from_posix() maps a C library signal number to a kernel signal number using the full
+ * table the POSIX layer owns. z_sig_shim() is the handler the POSIX layer registers with the
+ * kernel: it recovers the application handler from the action's user_data and invokes it with
+ * the C library's signal number.
+ */
+int z_sig_from_posix(int sig) __attribute__((__weak__));
+void z_sig_shim(int sig, struct k_sig_info *info, void *context) __attribute__((__weak__));
+
+#endif /* ZEPHYR_LIB_LIBC_COMMON_SOURCE_SIGNAL_SIG_ISOC_H_ */
diff --git a/lib/libc/common/source/signal/signal.c b/lib/libc/common/source/signal/signal.c
index 0f383180bc6..2e1584f33ab 100644
--- a/lib/libc/common/source/signal/signal.c
+++ b/lib/libc/common/source/signal/signal.c
@@ -3,13 +3,57 @@
  * SPDX-FileCopyrightText: Copyright The Zephyr Project Contributors
  */

+#include "sig_isoc.h"
+
 #include <errno.h>
 #include <signal.h>

-void (*signal(int signum, void (*handler)(int)))(int)
+#include <zephyr/kernel.h>
+#include <zephyr/kernel/signal.h>
+
+void (*signal(int sig, void (*func)(int)))(int)
 {
-	ARG_UNUSED(signum);
-	ARG_UNUSED(handler);
-	errno = EINVAL;
-	return SIG_ERR;
+	int ret;
+	int ksig;
+	struct k_sig_action oact;
+	struct k_sig_action act = {0};
+
+	ksig = (z_sig_from_posix != NULL) ? z_sig_from_posix(sig) : z_isoc_sig_to_k(sig);
+	if (ksig <= 0) {
+		errno = EINVAL;
+		return SIG_ERR;
+	}
+
+	if ((func == SIG_DFL) || (func == SIG_IGN)) {
+		act.handler = (func == SIG_IGN) ? K_SIG_IGN : K_SIG_DFL;
+	} else if (z_sig_shim != NULL) {
+		/*
+		 * The identical registration sigaction() makes for a plain handler, so a
+		 * disposition installed through either function is visible to the other.
+		 */
+		act.handler = z_sig_shim;
+		act.user_data = (void *)func;
+	} else {
+		/*
+		 * Without the POSIX layer only the six ISO C signal numbers are reachable, and
+		 * those coincide with the kernel's, so the handler can take delivery directly; it
+		 * ignores the trailing arguments the kernel passes.
+		 */
+		act.handler = (k_sig_handler_t)func;
+	}
+
+	/* ISO C dispositions carry no mask */
+	k_sig_emptyset(&act.mask);
+
+	ret = k_sig_action(ksig, &act, &oact);
+	if (ret < 0) {
+		errno = -ret;
+		return SIG_ERR;
+	}
+
+	if ((z_sig_shim != NULL) && (oact.handler == z_sig_shim)) {
+		return (void (*)(int))oact.user_data;
+	}
+
+	return (void (*)(int))oact.handler;
 }
diff --git a/lib/libc/common/source/stdlib/abort.c b/lib/libc/common/source/stdlib/abort.c
index 3b17be4a638..7441611fad1 100644
--- a/lib/libc/common/source/stdlib/abort.c
+++ b/lib/libc/common/source/stdlib/abort.c
@@ -7,8 +7,48 @@
 #include <stdlib.h>
 #include <zephyr/kernel.h>

+#ifdef CONFIG_COMMON_LIBC_SIGNAL
+
+#include <signal.h>
+#include <zephyr/kernel/signal.h>
+
+/*
+ * ISO C says abort() raises SIGABRT. POSIX adds that SIGABRT must not be blocked when abort() is
+ * called, and that abort() must terminate the caller even when SIGABRT is caught or ignored.
+ */
+static void abort_sigabrt(void)
+{
+	struct k_sig_set set;
+	struct k_sig_action dfl = {
+		.handler = K_SIG_DFL,
+		.flags = 0,
+	};
+
+	k_sig_emptyset(&dfl.mask);
+	k_sig_emptyset(&set);
+	(void)k_sig_addset(&set, K_SIG_ABRT);
+	(void)k_sig_mask(K_SIG_UNBLOCK, &set, NULL);
+
+	(void)raise(SIGABRT);
+
+	/*
+	 * Still here, so SIGABRT was ignored or a handler caught it and returned. Restore the
+	 * default disposition, which terminates the calling thread, and raise it once more.
+	 */
+	(void)k_sig_action(K_SIG_ABRT, &dfl, NULL);
+	(void)raise(SIGABRT);
+}
+
+#else
+
+#define abort_sigabrt() do { } while (false)
+
+#endif /* CONFIG_COMMON_LIBC_SIGNAL */
+
 FUNC_NORETURN void abort(void)
 {
+	abort_sigabrt();
+
 	printk("abort()\n");
 	k_panic();
 	CODE_UNREACHABLE;
