menu "POSIX signals"

config POSIX_REALTIME_SIGNALS
	bool "POSIX realtime signals"
	help
	  Enable support for POSIX realtime signals.

if POSIX_REALTIME_SIGNALS

config SIGNAL_QUEUE_SIZE_ADD_POSIX_REALTIME
	def_int 32
	help
	  This value represents the maximum number of signals that a process may send or have pending
	  at any given time (see SIGQUEUE_MAX and
	  _POSIX_SIGQUEUE_MAX limits.h).

config POSIX_RTSIG_MAX
	int "Maximum number of realtime signals"
	default 8
	help
	  Define the maximum number of realtime signals (RTSIG_MAX).
	  The range of realtime signals is [SIGRTMIN .. (SIGRTMIN+RTSIG_MAX)]

# it would be much better to use arithmetic + variables here but it does not work
config SIGNAL_SET_SIZE_MIN_POSIX_REALTIME
	def_int 42
	help
	  This number of signals required for POSIX real-time extensions.
	  
	  When enabled, this option ensures the value of SIGNAL_SET_SIZE is at least 42.

endif # POSIX_REALTIME_SIGNALS

config POSIX_SIGNALS
	bool "POSIX signals"
	select POSIX_MULTI_PROCESS
	help
	  Enable support for POSIX signals.

if POSIX_SIGNALS

config SIGNAL_SET_SIZE_MIN_POSIX
	def_int 32
	help
	  This number of signals required for POSIX conformance.
	  
	  When enabled, this option ensures the value of SIGNAL_SET_SIZE is at least 32.

# These options are intended to be used for compatibility with external POSIX
# implementations such as those in Newlib or Picolibc.

config POSIX_SIGNALS_ALIAS_KILL
	bool

endif

endmenu # "Signal support"
