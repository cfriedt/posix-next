diff --git a/arch/riscv/core/signal.c b/arch/riscv/core/signal.c
new file mode 100644
index 00000000000..8b8448fe3a2
--- /dev/null
+++ b/arch/riscv/core/signal.c
@@ -0,0 +1,33 @@
+/*
+ * Copyright (c) 2026, Friedt Professional Engineering Services, Inc.
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+#include <zephyr/kernel.h>
+
+void arch_sig_pre(struct k_thread *thread, void *arg)
+{
+	struct arch_esf *const esf = arg;
+	struct arch_sig_ctx *const sig = &thread->base.sig.user;
+
+	/* Backup the original RA, SP, A0, and MEPC into storage */
+	sig->ra = esf->ra;
+	sig->sp = esf->sp;
+	sig->a0 = esf->a0;
+	sig->mepc = esf->mepc;
+
+	/* Overwrite MEPC to resume execution in arch_sig_trampoline() */
+	esf->mepc = (unsigned long)arch_sig_trampoline;
+}
+
+void arch_sig_post(struct k_thread *thread, void *arg)
+{
+	struct arch_esf *const esf = arg;
+	struct arch_sig_ctx *const sig = &thread->base.sig.user;
+
+	/* Restore the original RA, SP, A0, and MEPC into esf */
+	esf->ra = sig->ra;
+	esf->sp = sig->sp;
+	esf->a0 = sig->a0;
+	esf->mepc = sig->mepc;
+}
diff --git a/include/zephyr/arch/riscv/exception.h b/include/zephyr/arch/riscv/exception.h
index e02037b66c0..8a89d1c9a8d 100644
--- a/include/zephyr/arch/riscv/exception.h
+++ b/include/zephyr/arch/riscv/exception.h
@@ -105,6 +105,26 @@ struct arch_esf {
 typedef struct soc_esf soc_esf_t;
 #endif

+#if defined(CONFIG_SIGNAL) && defined(CONFIG_USERSPACE)
+struct arch_sig_ctx {
+	unsigned long ra;		/* return address */
+	unsigned long a0;		/* function argument/return value */
+	unsigned long mepc;		/* machine exception program counter */
+	unsigned long sp;               /* preserved (user or kernel) stack pointer */
+	/*
+	 * Callee-saved registers of the interrupted context (s0 is preserved via the esf). The
+	 * signal trampoline chain clobbers them per the ABI, and k_sig_return() resumes the
+	 * interrupted context without unwinding the trampoline's frames, so they are captured at
+	 * redirection and restored on the k_sig_return() exit path.
+	 */
+#if defined(CONFIG_RISCV_ISA_RV32E)
+	unsigned long s[1];             /* s1 */
+#else
+	unsigned long s[11];            /* s1..s11 */
+#endif
+};
+#endif
+
 #ifdef __cplusplus
 }
 #endif
