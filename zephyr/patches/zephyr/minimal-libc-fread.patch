+size_t z_impl_zephyr_fread(void *ZRESTRICT ptr, size_t size, size_t nitems,
+			   FILE *ZRESTRICT stream)
+{
+	size_t nbyte;
+	size_t nread;
+
+	if ((nitems == 0) || (size == 0)) {
+		return 0;
