diff --git a/include/zephyr/sys/timeutil.h b/include/zephyr/sys/timeutil.h
index 5eb23abfdd0..0e4978c57f9 100644
--- a/include/zephyr/sys/timeutil.h
+++ b/include/zephyr/sys/timeutil.h
@@ -690,6 +690,38 @@ static inline k_timeout_t timespec_to_timeout(const struct timespec *req, struct
 	return timeout;
 }

+/**
+ * @brief Convert an absolute clock timespec to a kernel timepoint
+ *
+ * In contrast to @ref timespec_to_timeout, which operates on relative time durations, this
+ * function converts the absolute time point described by @p abstime to a @ref k_timepoint_t which
+ * is currently specified as a number of ticks relative to system boot.
+ *
+ * @param abstime absolute time to convert
+ * @param clock_id clock by which @p abstime is measured
+ * @return the equivalent kernel time point
+ */
+k_timepoint_t timespec_abs_to_timepoint(uint32_t clock_id, const struct timespec *abstime);
+
+/**
+ * @brief Convert an absolute realtime clock timespec to a kernel timepoint
+ *
+ * In contrast to @ref timespec_to_timeout, which operates on relative time durations, this
+ * function converts the absolute time point described by @p abstime to a @ref k_timepoint_t which
+ * is currently specified as a number of ticks relative to system boot.
+ *
+ * Furthermore, this function assumes that @p abstime is defined with respect to the "wall clock",
+ * @ref SYS_CLOCK_REALTIME, and that it is defined with respect to the epoch, on January 1, 1970
+ * at 00:00:00 UTC.
+ *
+ * @param abstime absolute time to convert
+ * @return the equivalent kernel time point
+ */
+ static inline k_timepoint_t timespec_abs_rt_to_timepoint(const struct timespec *abstime)
+ {
+	return timespec_abs_to_timepoint(SYS_CLOCK_REALTIME, abstime);
+ }
+
 /**
  * @}
  */
diff --git a/lib/utils/timeutil.c b/lib/utils/timeutil.c
index c42d977338f..05bce5ed9ba 100644
--- a/lib/utils/timeutil.c
+++ b/lib/utils/timeutil.c
@@ -241,3 +241,17 @@ bool timespec_normalize(struct timespec *ts)

 	return true;
 }
+
+k_timepoint_t timespec_abs_to_timepoint(uint32_t clock_id, const struct timespec *abstime)
+{
+	struct timespec now;
+	int __maybe_unused rc;
+	struct timespec duration = *abstime;
+
+	rc = sys_clock_gettime(clock_id, &now);
+	__ASSERT(rc == 0, "%s() %s: %d", "sys_clock_gettime", "failed", rc);
+	rc = (int)timespec_sub(&duration, &now);
+	__ASSERT(rc == 1, "%s() %s: %d", "timespec_sub", "overflowed", rc);
+
+	return sys_timepoint_calc(timespec_to_timeout(&duration, NULL));
+}
