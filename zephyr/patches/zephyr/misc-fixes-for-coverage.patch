diff --git a/arch/riscv/core/pmp.c b/arch/riscv/core/pmp.c
index 49828513d71..ede5bae92ed 100644
--- a/arch/riscv/core/pmp.c
+++ b/arch/riscv/core/pmp.c
@@ -405,6 +405,23 @@ void z_riscv_pmp_init(void)
 		      (size_t)__rom_region_size,
 		      pmp_addr, pmp_cfg, ARRAY_SIZE(pmp_addr));
 
+#if defined(CONFIG_COVERAGE_GCOV) && defined(CONFIG_USERSPACE)
+	/*
+	 * GCOV counters live in __gcov_bss and must be writable from user mode
+	 * when instrumented code (e.g. z_thread_entry) runs after mret.
+	 */
+	uintptr_t gcov_start = (uintptr_t)__gcov_bss_start;
+	size_t gcov_size = (uintptr_t)__gcov_bss_end - gcov_start;
+
+	if (gcov_size > 0U) {
+		__ASSERT(set_pmp_entry(&index, PMP_R | PMP_W,
+						gcov_start, gcov_size,
+						pmp_addr, pmp_cfg,
+						ARRAY_SIZE(pmp_addr)),
+				"failed to map __gcov_bss for coverage");
+	}
+#endif
+
