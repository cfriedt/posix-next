index 117944dbdc6..03b25690eea 100644
--- a/lib/os/zvfs/Kconfig
+++ b/lib/os/zvfs/Kconfig
@@ -14,6 +14,80 @@ menuconfig ZVFS
 
 if ZVFS
 
+config ZVFS_LIBC_FILE_SIZE
+	int
+	default -1
+	help
+	  Override for the size, in bytes, of a C library FILE object as stored in the ZVFS FILE
+	  store. When positive, zvfs_libc.h exposes this value as ZVFS_LIBC_FILE_SIZE; otherwise
+	  ZVFS_LIBC_FILE_SIZE defaults to sizeof(FILE). Picolibc and newlib override this when the
+	  active FILE representation (including any embedded stdio buffer and lock) is larger than
+	  sizeof(FILE).
+
+config ZVFS_LIBC_FILE_ALIGN
+	int
+	default -1
+	help
+	  Override for the alignment, in bytes, of C library FILE objects in the ZVFS FILE store.
+	  When positive, zvfs_libc.h exposes this value as ZVFS_LIBC_FILE_ALIGN; otherwise
+	  ZVFS_LIBC_FILE_ALIGN defaults to _Alignof(FILE).
+
+config ZVFS_FS
+	bool "ZVFS path open via Zephyr file system"
+	depends on FILE_SYSTEM
+	default y
+	help
+	  Build the ZVFS path opener (zvfs_open) that wraps Zephyr fs_open() and
+	  registers a file in the fd table. Required for ISO C fopen() and for POSIX
+	  open() when a mounted file system is present.
+
+config ZVFS_LIBC_FILE
+	bool
+	default y if ZVFS_FS && !MINIMAL_LIBC
+	help
+	  Build the generic, statically-allocated C library FILE-object store
+	  (lib/os/zvfs/zvfs_libc_file.c). It provides the allocation-free backing storage that each
+	  C library's zvfs_libc_fdopen() hook draws from to bind a FILE to a ZVFS file descriptor.
+
+	  Minimal libc encodes a FILE directly as an fd and does not use this store, so it is not
+	  selected there.
+
+	  Every C library that uses the store must provide the two non-POSIX hooks:
+
+	  - FILE *zvfs_libc_fdopen(int fd, const char *mode);
+	  - int zvfs_libc_fileno(FILE *fp);
+
+config ZVFS_FS_DESC_MAX
+	int
+	depends on ZVFS_FS
+	default ZVFS_OPEN_MAX if ZVFS_OPEN_MAX > 0
+	default 16
+	help
+	  Maximum concurrent Zephyr FS objects tracked by the ZVFS FS descriptor
+	  pool (open files and directory streams).
+
+config ZVFS_OPEN_ADD_SIZE_FS
+	int
+	depends on ZVFS_FS
+	default 4
+	help
+	  Number of file descriptors reserved for ZVFS path opens via zvfs_open()
+	  (ISO C fopen()/freopen() and POSIX open() on a mounted file system).
+
+config ZVFS_RESERVE_STDIO_FDS
+	bool
+	help
+	  Pre-reserve fd slots 0, 1, and 2 for stdin, stdout, and stderr in the ZVFS fd
+	  table so dynamically allocated descriptors start at fd 3.
+
+config ZVFS_OPEN_ADD_SIZE_STDIO
+	int
+	default 3 if ZVFS_RESERVE_STDIO_FDS
+	default 0
+	help
+	  Number of file descriptors reserved for stdin, stdout, and stderr in the ZVFS
+	  fd table size calculation.
+
 config ZVFS_EVENTFD
 	bool "ZVFS event file descriptor support"
 	imply ZVFS_POLL
diff --git a/lib/os/zvfs/zvfs_fs.c b/lib/os/zvfs/zvfs_fs.c
new file mode 100644
index 00000000000..222ed7e8c3e
--- /dev/null
+++ b/lib/os/zvfs/zvfs_fs.c
@@ -0,0 +1,294 @@
+/*
+ * SPDX-FileCopyrightText: Copyright The Zephyr Project Contributors
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+/**
+ * @file
+ * @brief ZVFS path open via the Zephyr file system.
+ *
+ * Wraps Zephyr fs_open() and registers the result in the generic fd table so that
+ * ISO C fopen() and POSIX open() can share the same fd-backed I/O path.
+ */
+
+#include <errno.h>
+#include <stdarg.h>
+#include <string.h>
+
+#if defined(CONFIG_MINIMAL_LIBC)
+#define _POSIX_C_SOURCE 200809L
+#define _XOPEN_SOURCE 700
+#include <zephyr/posix/sys/stat.h>
+#else
+#include <sys/stat.h>
+#endif
+
+#include <zephyr/fs/fs.h>
+#include <zephyr/kernel.h>
+#include <zephyr/sys/fdtable.h>
+#include <zephyr/sys/zvfs_fs.h>
+
+#define ZVFS_O_ACCMODE (ZVFS_O_RDONLY | ZVFS_O_WRONLY | ZVFS_O_RDWR)
+
+static struct zvfs_fs_desc desc_array[CONFIG_ZVFS_FS_DESC_MAX];
+
+static struct fd_op_vtable fs_fd_op_vtable;
+
+struct zvfs_fs_desc *zvfs_fs_desc_alloc(bool is_dir)
+{
+	struct zvfs_fs_desc *ptr = NULL;
+	unsigned int key = irq_lock();
+
+	for (int i = 0; i < CONFIG_ZVFS_FS_DESC_MAX; i++) {
+		if (!desc_array[i].used) {
+			ptr = &desc_array[i];
+			ptr->used = true;
+			ptr->is_dir = is_dir;
+			break;
+		}
+	}
+
+	irq_unlock(key);
+
+	return ptr;
+}
+
+void zvfs_fs_desc_free(struct zvfs_fs_desc *ptr)
+{
+	if (ptr != NULL) {
+		ptr->used = false;
+	}
+}
+
+static int posix_mode_to_zephyr(int mf)
+{
+	int mode = (mf & ZVFS_O_CREAT) ? FS_O_CREATE : 0;
+
+	mode |= (mf & ZVFS_O_APPEND) ? FS_O_APPEND : 0;
+	mode |= (mf & ZVFS_O_TRUNC) ? FS_O_TRUNC : 0;
+
+	switch (mf & ZVFS_O_ACCMODE) {
+	case ZVFS_O_RDONLY:
+		mode |= FS_O_READ;
+		break;
+	case ZVFS_O_WRONLY:
+		mode |= FS_O_WRITE;
+		break;
+	case ZVFS_O_RDWR:
+		mode |= FS_O_RDWR;
+		break;
+	default:
+		break;
+	}
+
+	return mode;
+}
+
+int zvfs_open(const char *name, int flags, int mode)
+{
+	int rc, fd;
+	struct zvfs_fs_desc *ptr = NULL;
+	int zmode = posix_mode_to_zephyr(flags);
+
+	if (zmode < 0) {
+		return zmode;
+	}
+
+	fd = zvfs_reserve_fd();
+	if (fd < 0) {
+		return -1;
+	}
+
+	ptr = zvfs_fs_desc_alloc(false);
+	if (ptr == NULL) {
+		rc = -EMFILE;
+		goto out_err;
+	}
+
+	fs_file_t_init(&ptr->file);
+
+	if (flags & ZVFS_O_CREAT) {
+		flags &= ~ZVFS_O_CREAT;
+
+		rc = fs_open(&ptr->file, name, FS_O_CREATE | (zmode & FS_O_RDWR));
+		if (rc < 0) {
+			goto out_err;
+		}
+		rc = fs_close(&ptr->file);
+		if (rc < 0) {
+			goto out_err;
+		}
+	}
+
+	rc = fs_open(&ptr->file, name, zmode);
+	if (rc < 0) {
+		goto out_err;
+	}
+
+	zvfs_finalize_typed_fd(fd, ptr, &fs_fd_op_vtable, ZVFS_MODE_IFREG);
+
+	return fd;
+
+out_err:
+	if (ptr != NULL) {
+		zvfs_fs_desc_free(ptr);
+	}
+
+	zvfs_free_fd(fd);
+	errno = -rc;
+	return -1;
+}
+
+static int fs_close_vmeth(void *obj)
+{
+	struct zvfs_fs_desc *ptr = obj;
+	int rc;
+
+	rc = fs_close(&ptr->file);
+	zvfs_fs_desc_free(ptr);
+
+	return rc;
+}
+
+static int fs_ioctl_vmeth(void *obj, unsigned int request, va_list args)
+{
+	int rc = 0;
+	struct zvfs_fs_desc *ptr = obj;
+
+	switch (request) {
+	case ZFD_IOCTL_STAT: {
+		struct stat *buf = va_arg(args, struct stat *);
+		long offset = fs_tell(&ptr->file);
+		long current;
+
+		if (offset < 0) {
+			return offset;
+		}
+
+		memset(buf, 0, sizeof(struct stat));
+
+		rc = fs_seek(&ptr->file, 0, FS_SEEK_END);
+		if (rc < 0) {
+			return rc;
+		}
+
+		current = fs_tell(&ptr->file);
+		if (current >= 0) {
+			buf->st_size = current;
+			buf->st_mode = ptr->is_dir ? S_IFDIR : S_IFREG;
+		}
+
+		rc = fs_seek(&ptr->file, offset, FS_SEEK_SET);
+
+		if (current < 0) {
+			rc = current;
+		}
+		break;
+	}
+	case ZFD_IOCTL_FSYNC: {
+		rc = fs_sync(&ptr->file);
+		break;
+	}
+	case ZFD_IOCTL_LSEEK: {
+		off_t offset;
+		int whence;
+
+		offset = va_arg(args, off_t);
+		whence = va_arg(args, int);
+
+		rc = fs_seek(&ptr->file, offset, whence);
+		if (rc == 0) {
+			rc = fs_tell(&ptr->file);
+		}
+		break;
+	}
+	case ZFD_IOCTL_TRUNCATE: {
+		off_t length;
+
+		length = va_arg(args, off_t);
+
+		rc = fs_truncate(&ptr->file, length);
+		if (rc < 0) {
+			errno = -rc;
+			return -1;
+		}
+		break;
+	}
+	default:
+		errno = EOPNOTSUPP;
+		return -1;
+	}
+
+	if (rc < 0) {
+		errno = -rc;
+		return -1;
+	}
+
+	return rc;
+}
+
+static ssize_t fs_write_vmeth(void *obj, const void *buffer, size_t count)
+{
+	ssize_t rc;
+	struct zvfs_fs_desc *ptr = obj;
+
+	rc = fs_write(&ptr->file, buffer, count);
+	if (rc < 0) {
+		errno = -rc;
+		return -1;
+	}
+
+	return rc;
+}
+
+static ssize_t fs_write_offs_vmeth(void *obj, const void *buffer, size_t count,
+				   size_t offset)
+{
+	struct zvfs_fs_desc *ptr = obj;
+	ssize_t rc;
+
+	rc = fs_seek(&ptr->file, (off_t)offset, FS_SEEK_SET);
+	if (rc < 0) {
+		errno = -rc;
+		return -1;
+	}
+
+	return fs_write_vmeth(obj, buffer, count);
+}
+
+static ssize_t fs_read_vmeth(void *obj, void *buffer, size_t count)
+{
+	ssize_t rc;
+	struct zvfs_fs_desc *ptr = obj;
+
+	rc = fs_read(&ptr->file, buffer, count);
+	if (rc < 0) {
+		errno = -rc;
+		return -1;
+	}
+
+	return rc;
+}
+
+static ssize_t fs_read_offs_vmeth(void *obj, void *buffer, size_t count, size_t offset)
+{
+	struct zvfs_fs_desc *ptr = obj;
+	ssize_t rc;
+
+	rc = fs_seek(&ptr->file, (off_t)offset, FS_SEEK_SET);
+	if (rc < 0) {
+		errno = -rc;
+		return -1;
+	}
+
+	return fs_read_vmeth(obj, buffer, count);
+}
+
+static struct fd_op_vtable fs_fd_op_vtable = {
+	.read = fs_read_vmeth,
+	.read_offs = fs_read_offs_vmeth,
+	.write = fs_write_vmeth,
+	.write_offs = fs_write_offs_vmeth,
+	.close = fs_close_vmeth,
+	.ioctl = fs_ioctl_vmeth,
+};
diff --git a/lib/os/zvfs/zvfs_libc_file.c b/lib/os/zvfs/zvfs_libc_file.c
new file mode 100644
index 00000000000..36e1e17c13e
--- /dev/null
+++ b/lib/os/zvfs/zvfs_libc_file.c
@@ -0,0 +1,95 @@
+/*
+ * SPDX-FileCopyrightText: Copyright The Zephyr Project Contributors
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+/**
+ * @file
+ * @brief Generic, statically-allocated C library FILE-object store.
+ *
+ * This provides the allocation-free backing store for the per-libc
+ * zvfs_libc_fdopen() hooks. Slots are reserved at build time via a k_mem_slab so
+ * that no dynamic memory allocation is ever required to bind a C library FILE to
+ * a ZVFS file descriptor.
+ *
+ * The store is deliberately libc-agnostic: it hands out raw, uninitialized
+ * storage and tracks which fd each slot currently backs. The active C library is
+ * responsible for initializing that storage as a FILE (in its zvfs_libc_fdopen()
+ * hook) and for reading the fd back out of a FILE (in zvfs_libc_fileno()). This
+ * keeps the dependency strictly downward: the libc calls into this store; this
+ * store never calls up into the libc.
+ */
+
+#include <stdbool.h>
+#include <stddef.h>
+#include <stdint.h>
+
+#include <zephyr/kernel.h>
+#include <zephyr/sys/util.h>
+#include <zephyr/sys/zvfs_libc.h>
+
+BUILD_ASSERT(ZVFS_LIBC_FILE_SIZE > 0, "ZVFS_LIBC_FILE_SIZE must be positive");
+BUILD_ASSERT((ZVFS_LIBC_FILE_SIZE % ZVFS_LIBC_FILE_ALIGN) == 0,
+	     "ZVFS_LIBC_FILE_SIZE must be a multiple of ZVFS_LIBC_FILE_ALIGN");
+
+K_MEM_SLAB_DEFINE_STATIC(zvfs_libc_file_slab, ZVFS_LIBC_FILE_SIZE, ZVFS_OPEN_SIZE,
+			 ZVFS_LIBC_FILE_ALIGN);
+
+/* Maps a slab block index to the fd it currently backs (-1 if free). */
+static int file_to_fd[ZVFS_OPEN_SIZE] = {
+#if ZVFS_OPEN_SIZE > 0
+	[0 ... ZVFS_OPEN_SIZE - 1] = -1,
+#endif
+};
+
+static inline uint8_t *slab_base(void)
+{
+	return (uint8_t *)zvfs_libc_file_slab.buffer;
+}
+
+static inline bool slab_contains(const void *fp)
+{
+	const uint8_t *p = (const uint8_t *)fp;
+	const uint8_t *base = slab_base();
+
+	return (p >= base) && (p < (base + (size_t)ZVFS_OPEN_SIZE * ZVFS_LIBC_FILE_SIZE));
+}
+
+static inline int slab_index(const void *fp)
+{
+	return (int)(((const uint8_t *)fp - slab_base()) / ZVFS_LIBC_FILE_SIZE);
+}
+
+void *zvfs_libc_file_alloc(int fd, k_timeout_t timeout)
+{
+	void *fp = NULL;
+
+	if (k_mem_slab_alloc(&zvfs_libc_file_slab, &fp, timeout) != 0) {
+		return NULL;
+	}
+
+	file_to_fd[slab_index(fp)] = fd;
+
+	return fp;
+}
+
+void zvfs_libc_file_free(void *fp)
+{
+	if ((fp == NULL) || !slab_contains(fp)) {
+		return;
+	}
+
+	file_to_fd[slab_index(fp)] = -1;
+	k_mem_slab_free(&zvfs_libc_file_slab, fp);
+}
+
+void *zvfs_libc_file_from_fd(int fd)
+{
+	for (int i = 0; i < (int)ARRAY_SIZE(file_to_fd); i++) {
+		if (file_to_fd[i] == fd) {
+			return slab_base() + (size_t)i * ZVFS_LIBC_FILE_SIZE;
+		}
+	}
+
+	return NULL;
+}
