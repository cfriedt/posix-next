diff --git a/arch/arm/core/signal.c b/arch/arm/core/signal.c
new file mode 100644
index 00000000000..4a67e34e7d6
--- /dev/null
+++ b/arch/arm/core/signal.c
@@ -0,0 +1,38 @@
+/*
+ * Copyright (c) 2026, Friedt Professional Engineering Services, Inc.
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include <zephyr/kernel.h>
+
+void arch_sig_pre(struct k_thread *thread, void *arg)
+{
+	struct arch_sig_ctx *const psf = arg;
+	struct arch_sig_ctx *const backup = &thread->base.sig.user;
+
+	/*
+	 * Backup the original SP, PC (return address), LR, and R0 from PSF. The PSF is a
+	 * four-word stack frame: it does not carry the callee-saved registers, which are
+	 * captured separately in assembly at redirection.
+	 */
+	backup->sp = psf->sp;
+	backup->lr = psf->lr;
+	backup->r0 = psf->r0;
+	backup->pc = psf->pc;
+
+	/* Overwrite PC (return address) to resume execution in arch_sig_trampoline() */
+	psf->pc = (unsigned long)arch_sig_trampoline;
+}
+
+void arch_sig_post(struct k_thread *thread, void *arg)
+{
+	struct arch_sig_ctx *const psf = arg;
+	struct arch_sig_ctx *const backup = &thread->base.sig.user;
+
+	/* Restore the original SP, PC (return address), LR, and R0 into PSF */
+	psf->sp = backup->sp;
+	psf->lr = backup->lr;
+	psf->r0 = backup->r0;
+	psf->pc = backup->pc;
+}
diff --git a/arch/arm/core/userspace.S b/arch/arm/core/userspace.S
index 92795625a1d..46971af99c0 100644
--- a/arch/arm/core/userspace.S
+++ b/arch/arm/core/userspace.S
@@ -32,6 +32,10 @@ GDATA(_kernel)
 /* Imports */
 GDATA(_k_syscall_table)

+#if defined(CONFIG_SIGNAL)
+GTEXT(z_sig_handle)
+#endif
+
 /**
  *
  * User space entry function
@@ -365,6 +369,7 @@ dispatch_syscall:
     lsls r6, #2
     add r0, r6
     ldr r0, [r0]	/* load table address */
+    lsr r6, #2          /* preserve syscall id */
     /* swap ip and r0, restore r1 from lr */
     mov r1, ip
     mov ip, r0
@@ -405,6 +410,7 @@ dispatch_syscall:
     lsl r6, #2
     add ip, r6
     ldr ip, [ip]	/* load table address */
+    lsr r6, #2          /* preserve syscall id */

     /* execute function from dispatch table */
     blx ip
@@ -413,6 +419,85 @@ dispatch_syscall:
     ldr lr, [sp,#16]
 #endif

+    /* restore stack pointer to its original location */
+    pop {r4,r5,ip}
+
+#ifdef CONFIG_SIGNAL
+    ldr ip, =K_SYSCALL_K_SIG_ACTION
+    cmp ip, r6
+    beq .L_skip_k_sig_handle
+    ldr ip, =K_SYSCALL_K_SIG_CURRENT
+    cmp ip, r6
+    beq .L_skip_k_sig_handle
+    ldr ip, =K_SYSCALL_K_SIG_RETURN
+    cmp ip, r6
+    beq .L_do_sig_return_restore
+
+    /* Store LR into privileged stack */
+    str lr, [sp,#4]
+    /* Store R0 (syscall return value) into privileged stack */
+    str r0, [sp,#8]
+    /* Store PC (return address) into privileged stack from R8 */
+    str r8, [sp,#12]
+
+    /* Pass privileged stack to z_sig_handle() */
+    mov r0, sp
+    ldr ip, =z_sig_handle
+    blx ip
+    cmp r0, #0
+    beq .L_do_sig_restore
+
+    /*
+     * z_sig_handle() redirected the return path into the signal trampoline. The trampoline
+     * chain clobbers the callee-saved registers per the ABI and k_sig_return() resumes the
+     * interrupted context without unwinding, so capture them now: at this point they still
+     * hold the interrupted context's values.
+     */
+    ldr r0, =_kernel
+    ldr r0, [r0, #_kernel_offset_to_current]
+    ldr r1, =__thread_sig_user_s_OFFSET
+    add r0, r0, r1
+#if defined(CONFIG_ARMV6_M_ARMV8_M_BASELINE)
+    stmia r0!, {r4-r7}
+    mov r1, r8
+    mov r2, r9
+    mov r3, r10
+    stmia r0!, {r1-r3}
+    mov r1, r11
+    str r1, [r0]
+#else
+    stmia r0, {r4-r11}
+#endif
+    b .L_do_sig_restore
+
+.L_do_sig_return_restore:
+    /* restore the callee-saved registers captured when the trampoline was entered */
+    ldr r0, =_kernel
+    ldr r0, [r0, #_kernel_offset_to_current]
+    ldr r1, =__thread_sig_user_s_OFFSET
+    add r0, r0, r1
+#if defined(CONFIG_ARMV6_M_ARMV8_M_BASELINE)
+    ldmia r0!, {r4-r7}
+    ldmia r0!, {r1-r3}
+    mov r8, r1
+    mov r9, r2
+    mov r10, r3
+    ldr r1, [r0]
+    mov r11, r1
+#else
+    ldmia r0, {r4-r11}
+#endif
+
+.L_do_sig_restore:
+    /* Retore LR from privileged stack */
+    ldr lr, [sp,#4]
+    /* Restore R0 (syscall return value) from privileged stack */
+    ldr r0, [sp,#8]
+    /* Restore PC (return address) from privileged stack into R8 */
+    ldr r8, [sp,#12]
+
+.L_skip_k_sig_handle:
+#endif

 #if defined(CONFIG_BUILTIN_STACK_GUARD)
     /*
@@ -451,14 +536,14 @@ dispatch_syscall:
     /* set stack back to unprivileged stack */
     mov ip, r0
     mov r0, sp
-    ldr r0, [r0,#12]
+    ldr r0, [r0]
     msr PSP, r0
     /* Restore r0 */
     mov r0, ip

 #elif defined(CONFIG_ARMV7_M_ARMV8_M_MAINLINE)
     /* set stack back to unprivileged stack */
-    ldr ip, [sp,#12]
+    ldr ip, [sp]
     msr PSP, ip
 #endif

