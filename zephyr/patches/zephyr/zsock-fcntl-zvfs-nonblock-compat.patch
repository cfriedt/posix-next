--- a/lib/libc/arcmwdt/include/fcntl.h
+++ b/lib/libc/arcmwdt/include/fcntl.h
@@ -8,21 +8,36 @@
 #define ZEPHYR_LIB_LIBC_ARCMWDT_INCLUDE_FCNTL_H_
 
 #include_next <fcntl.h>
