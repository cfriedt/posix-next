diff --git a/include/zephyr/sys/zvfs.h b/include/zephyr/sys/zvfs.h
index ab4d985f..7bc973b6 100644
--- a/include/zephyr/sys/zvfs.h
+++ b/include/zephyr/sys/zvfs.h
@@ -102,15 +102,17 @@ __syscall int zvfs_ftruncate(int fd, off_t length);
 /**
  * @brief Dispatch a control request on a file descriptor.
  *
- * Callers marshal arguments before dispatching through the fd vtable.
+ * @p arg is command-specific: an @c int for most requests, or a pointer to
+ * @ref zvfs_flock for record-lock commands. Commands and flag values use ZVFS
+ * constants (see @ref fdtable.h), not POSIX @c fcntl.h values.
  *
  * @param fd File descriptor.
- * @param cmd Control command.
- * @param args Command arguments.
+ * @param cmd ZVFS control command.
+ * @param arg Command argument.
  *
  * @return Command-specific result, or -1 on error (errno is set).
  */
-int zvfs_fcntl(int fd, int cmd, va_list args);
+__syscall int zvfs_fcntl(int fd, int cmd, uintptr_t arg);

 /**
  * @brief Duplicate a file descriptor to the lowest available slot >= minfd.
diff --git a/lib/os/zvfs/zvfs_fcntl.c b/lib/os/zvfs/zvfs_fcntl.c
index fb4078f4..0d6e60b4 100644
--- a/lib/os/zvfs/zvfs_fcntl.c
+++ b/lib/os/zvfs/zvfs_fcntl.c
@@ -1,14 +1,17 @@
 /*
  * SPDX-FileCopyrightText: Copyright The Zephyr Project Contributors
+ * Copyright (c) 2024, Friedt Professional Engineering Services, Inc.
  * SPDX-License-Identifier: Apache-2.0
  */

+#include <errno.h>
 #include <stdarg.h>

 #include <zephyr/sys/fdtable.h>
 #include <zephyr/sys/internal/fdtable_priv.h>
+#include <zephyr/internal/syscall_handler.h>

-int zvfs_fcntl(int fd, int cmd, va_list args)
+int z_impl_zvfs_fcntl(int fd, int cmd, uintptr_t arg)
 {
 	struct fd_entry *entry = zvfs_fd_entry_get(fd);

@@ -16,4 +19,80 @@ int zvfs_fcntl(int fd, int cmd, va_list args)
 		return -1;
 	}

-	return entry->vtable->ioctl(entry->obj, cmd, args);
+	switch (cmd) {
+	case ZVFS_F_GETFD:
+		return entry->fd_flags;
+
+	case ZVFS_F_SETFD:
+		entry->fd_flags = (int)arg & ZVFS_FD_CLOEXEC;
+		return 0;
+
+	case ZVFS_F_DUPFD:
+		return zvfs_dup(fd, (int)arg);
+
+	case ZVFS_F_DUPFD_CLOEXEC: {
+		struct fd_entry *dup_entry;
+		int dupfd;
+
+		dupfd = zvfs_dup(fd, (int)arg);
+		if (dupfd < 0) {
+			return -1;
+		}
+
+		dup_entry = zvfs_fd_entry_get(dupfd);
+		if (dup_entry == NULL) {
+			(void)zvfs_close(dupfd);
+			return -1;
+		}
+
+		dup_entry->fd_flags = ZVFS_FD_CLOEXEC;
+		return dupfd;
+	}
+
+	case ZVFS_F_GETLK:
+	case ZVFS_F_SETLK:
+	case ZVFS_F_SETLKW: {
+		struct zvfs_flock *lock = (struct zvfs_flock *)(uintptr_t)arg;
+
+		if (lock == NULL) {
+			errno = EINVAL;
+			return -1;
+		}
+
+#ifdef CONFIG_ZVFS_FS
+		return zvfs_record_lock_fcntl(entry, cmd, lock);
+#else
+		errno = EOPNOTSUPP;
+		return -1;
+#endif
+	}
+
+	default:
+		return zvfs_fdtable_call_ioctl(entry->vtable, entry->obj, cmd, (int)arg);
+	}
+}
+
+#ifdef CONFIG_USERSPACE
+static int z_vrfy_zvfs_fcntl(int fd, int cmd, uintptr_t arg)
+{
+	if (zvfs_fd_syscall_verify(fd) == NULL) {
+		return -1;
+	}
+
+	switch (cmd) {
+	case ZVFS_F_GETLK:
+		K_OOPS(K_SYSCALL_MEMORY_WRITE((void *)arg, sizeof(struct zvfs_flock)));
+		break;
+	case ZVFS_F_SETLK:
+	case ZVFS_F_SETLKW:
+		K_OOPS(K_SYSCALL_MEMORY_READ((void *)arg, sizeof(struct zvfs_flock)));
+		break;
+	default:
+		break;
+	}
+
+	return z_impl_zvfs_fcntl(fd, cmd, arg);
+}
+
+#include <zephyr/syscalls/zvfs_fcntl_mrsh.c>
+#endif /* CONFIG_USERSPACE */
