From cb93487e7e6e54a1f136ff3bef7affd3276c9680 Mon Sep 17 00:00:00 2001
From: Chris Friedt <chris@fr4.co>
Date: Sat, 25 Apr 2026 17:38:51 -0400
Subject: [PATCH] libc: picolibc: use k_thread_cleanup_push/pop in pthread.h

Stop declaring private __z_pthread_cleanup_push/pop prototypes and map
pthread_cleanup_push/pop directly to k_thread_cleanup_push/pop.

Signed-off-by: Friedt Professional Engineering Services, Inc
---
 lib/libc/picolibc/include/pthread.h | 9 ++++-----
 1 file changed, 4 insertions(+), 5 deletions(-)

diff --git a/lib/libc/picolibc/include/pthread.h b/lib/libc/picolibc/include/pthread.h
index fc5c6fd545a..9caecdd95a0 100644
--- a/lib/libc/picolibc/include/pthread.h
+++ b/lib/libc/picolibc/include/pthread.h
@@ -11,6 +11,8 @@
 #undef __dead2
 #define __dead2
 
+#include <zephyr/kernel.h>
+
 /* workaround until https://github.com/picolibc/picolibc/pull/1096 is fixed */
 #include <sys/types.h> /* for clock_t */
 #if defined(CONFIG_PICOLIBC_USE_MODULE)
@@ -32,18 +34,15 @@
 /* The minimum allowable stack size */
 #define PTHREAD_STACK_MIN K_KERNEL_STACK_LEN(0)
 
-void __z_pthread_cleanup_push(void *cleanup[3], void (*routine)(void *arg), void *arg);
-void __z_pthread_cleanup_pop(int execute);
-
 #undef pthread_cleanup_push
 #define pthread_cleanup_push(_rtn, _arg)                                                           \
 	do /* enforce '{'-like behaviour */ {                                                      \
 		void *_z_pthread_cleanup[3];                                                       \
-	__z_pthread_cleanup_push(_z_pthread_cleanup, _rtn, _arg)
+		k_thread_cleanup_push(_z_pthread_cleanup, _rtn, _arg)
 
 #undef pthread_cleanup_pop
 #define pthread_cleanup_pop(_ex)                                                                   \
-	__z_pthread_cleanup_pop(_ex);                                                              \
+		k_thread_cleanup_pop(_ex);                                                            \
 	} /* enforce '}'-like behaviour */                                                         \
 	while (0)
 
-- 
