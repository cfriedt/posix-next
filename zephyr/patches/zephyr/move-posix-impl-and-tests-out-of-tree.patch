-		key |= (unsigned char)(*p);
-	}
-
-	switch (key) {
-	case FNM_CC5('a', 'l', 'n', 'u', 'm'):
-		ret = !isalnum(ch);
-		break;
-	case FNM_CC5('a', 'l', 'p', 'h', 'a'):
-		ret = !isalpha(ch);
-		break;
-	case FNM_CC5('b', 'l', 'a', 'n', 'k'):
-		ret = !isblank(ch);
