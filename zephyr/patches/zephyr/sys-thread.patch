diff --git a/lib/os/Kconfig.sys_thread b/lib/os/Kconfig.sys_thread
new file mode 100644
index 00000000000..e14cd85312a
--- /dev/null
+++ b/lib/os/Kconfig.sys_thread
@@ -0,0 +1,135 @@
+# Copyright (c) 2026, Friedt Professional Engineering Services, Inc
+# SPDX-License-Identifier: Apache-2.0
+
+config SYS_THREAD
+	bool "Support shared pools of threading primitives"
+	select DYNAMIC_OBJECTS if USERSPACE
+	select MUTEX_OPTIONS
+	select SIGNAL
+	select SYS_ELASTIPOOL
+	select THREAD_MONITOR
+	select THREAD_STACK_INFO
+	# to support heap-based allocation by default, can be disabled
+	imply SYS_HASH_MAP
+	imply SYS_HASH_FUNC32
+	help
+	  Select 'y' here to support shared system pools of threading primitives such as
+	    - k_condvar
+		- k_mutex
+		- k_thread_stack_t
+		- k_thread
+
+if SYS_THREAD
+
+config SYS_THREAD_CONDVAR_MAX
+	int "Maximum size of system k_condvar pool"
+	default SYS_THREAD_CONDVAR_MIN
+	help
+	  This value represents the maximum number of condition variables that may be available to
+	  kernel or user threads in the system condition variable pool. If this value is equal to
+	  CONFIG_SYS_THREAD_CONDVAR_MIN, then only static allocations permitted via the system
+	  condition variable pool. If this value is greater than CONFIG_SYS_THREAD_CONDVAR_MIN, then
+	  maximally CONFIG_SYS_THREAD_CONDVAR_MAX - CONFIG_SYS_THREAD_CONDVAR_MIN condition
+	  variables may be allocated from the heap.
+
+	  CONFIG_SYS_THREAD_CONDVAR_MAX must be >= CONFIG_SYS_THREAD_CONDVAR_MIN.
+
+config SYS_THREAD_CONDVAR_MIN
+	int "Minimum size of system k_condvar pool"
+	default 0
+	help
+	  This value represents the minimum number of condition variables that are guaranteed to be
+	  available to kernel or user threads in the system condition variable pool. The minimum
+	  number is guaranteed via static allocation.
+
+	  CONFIG_SYS_THREAD_CONDVAR_MIN must be >= 0.
+
+config SYS_THREAD_MUTEX_MAX
+	int "Maximum size of system k_mutex pool"
+	default SYS_THREAD_MUTEX_MIN
+	help
+	  This value represents the maximum number of mutexes that may be available to
+	  kernel or user threads in the system mutex pool. If this value is equal to
+	  CONFIG_SYS_THREAD_MUTEX_MIN, then only static allocations are permitted via the system
+	  condition variable pool. If this value is greater than CONFIG_SYS_THREAD_MUTEX_MIN, then
+	  maximally CONFIG_SYS_THREAD_MUTEX_MAX - CONFIG_SYS_THREAD_MUTEX_MIN condition
+	  variables may be allocated from the heap.
+
+	  CONFIG_SYS_THREAD_MUTEX_MAX must be >= CONFIG_SYS_THREAD_MUTEX_MIN.
+
+config SYS_THREAD_MUTEX_MIN
+	int "Minimum size of system k_mutex pool"
+	default 0
+	help
+	  This value represents the minimum number of mutexes that are guaranteed to be
+	  available to kernel or user threads in the system mutex pool. The minimum
+	  number is guaranteed via static allocation.
+
+	  CONFIG_SYS_THREAD_MUTEX_MIN must be >= 0.
+
+config SYS_THREAD_STACK_MAX
+	int "Maximum size of system k_thread_stack_t pool"
+	default SYS_THREAD_STACK_MIN
+	help
+	  This value represents the maximum number of thread stacks that may be available to
+	  kernel or user threads in the system stack pool. If this value is equal to
+	  CONFIG_SYS_THREAD_STACK_MIN, then only static allocations are permitted via the system
+	  stack pool. If this value is greater than CONFIG_SYS_THREAD_STACK_MIN, then
+	  maximally CONFIG_SYS_THREAD_STACK_MAX - CONFIG_SYS_THREAD_STACK_MIN stacks
+	  may be allocated from the heap.
+
+	  CONFIG_SYS_THREAD_STACK_MAX must be >= CONFIG_SYS_THREAD_STACK_MIN.
+
+config SYS_THREAD_STACK_MIN
+	int "Minimum size of system k_thread_stack_t pool"
+	default 0
+	help
+	  This value represents the minimum number of thread stacks that are guaranteed to be
+	  available to kernel or user threads in the system stack pool. The minimum
+	  number is guaranteed via static allocation.
+
+	  CONFIG_SYS_THREAD_STACK_MIN must be >= 0.
+
+config SYS_THREAD_STACK_SIZE
+	int "Size of system thread stacks"
+	default 4096 if X86 || COVERAGE_GCOV
+	default 1024 if !X86 && !64BIT
+	default 2048 if !X86 && 64BIT
+	help
+	  Size of each thread stack in the system thread stack pool.
+
+config SYS_THREAD_THREAD_MAX
+	int "Maximum size of system k_thread pool"
+	default SYS_THREAD_THREAD_MIN
+	help
+	  This value represents the maximum number of threads that may be available to
+	  kernel or user threads in the system thread pool. If this value is equal to
+	  CONFIG_SYS_THREAD_THREAD_MIN, then only static allocations are permitted via the system
+	  thread pool. If this value is greater than CONFIG_SYS_THREAD_THREAD_MIN, then
+	  maximally CONFIG_SYS_THREAD_THREAD_MAX - CONFIG_SYS_THREAD_THREAD_MIN threads
+	  may be allocated from the heap.
+
+	  CONFIG_SYS_THREAD_THREAD_MAX must be >= CONFIG_SYS_THREAD_THREAD_MIN.
+
+config SYS_THREAD_THREAD_MIN
+	int "Minimum size of system k_thread pool"
+	default 0
+	help
+	  This value represents the minimum number of threads that are guaranteed to be
+	  available to kernel or user threads in the system thread pool. The minimum
+	  number is guaranteed via static allocation.
+
+	  CONFIG_SYS_THREAD_THREAD_MIN must be >= 0.
+
+config SYS_THREAD_RECYCLER_DELAY_MS
+	int "Delay for reclaiming dynamic thread stacks (ms)"
+	default 100
+	help
+	  Scheduled delay for recycling threads after a detached thread has terminated.
+
+module = SYS_THREAD
+module-str = Log level for system thread library
+module-help = Enables system thread logging.
+source "subsys/logging/Kconfig.template.log_config"
+
+endif # SYS_THREAD
diff --git a/lib/os/thread.c b/lib/os/thread.c
new file mode 100644
index 00000000000..9efe6d43482
--- /dev/null
+++ b/lib/os/thread.c
@@ -0,0 +1,667 @@
+/*
+ * Copyright (c) 2026, Friedt Professional Engineering Services, Inc
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include "../../kernel/include/kthread.h"
+#include <ksched.h>
+
+#include <zephyr/internal/syscall_handler.h>
+#include <zephyr/logging/log.h>
+#include <zephyr/kernel.h>
+#include <zephyr/kernel/thread_stack.h>
+#include <zephyr/kernel/internal/mm.h>
+#include <zephyr/sys/internal/kobject_internal.h>
+#include <zephyr/sys/thread.h>
+#include <zephyr/sys/elastipool.h>
+#include <zephyr/toolchain.h>
+
+#ifdef CONFIG_USERSPACE
+#define K_THREAD_STACK_ALIGN(size) Z_THREAD_STACK_OBJ_ALIGN(size)
+#else
+#define K_THREAD_STACK_ALIGN(size) Z_KERNEL_STACK_OBJ_ALIGN
+#endif
+
+/* For declaring an array of k_condvar */
+#define K_CONDVAR_ARRAY_DEFINE_ELEM(idx, name) Z_CONDVAR_INITIALIZER(name[idx])
+#define K_CONDVAR_ARRAY_DEFINE(name, num)                                                          \
+	__maybe_unused struct k_condvar name[] = {                                                 \
+		LISTIFY(num, K_CONDVAR_ARRAY_DEFINE_ELEM, (,), name) };
+
+/* For declaring an array of k_mutex */
+#define K_MUTEX_ARRAY_DEFINE_ELEM(idx, name) Z_MUTEX_INITIALIZER(name[idx])
+#define K_MUTEX_ARRAY_DEFINE(name, num)                                                            \
+	__maybe_unused struct k_mutex name[] = {LISTIFY(num, K_MUTEX_ARRAY_DEFINE_ELEM, (,), name) };
+
+#if defined(CONFIG_INIT_STACKS)
+#if (SYS_THREAD_STACK_MIN == 0)
+/* Currently, a non-NULL, non-zero-sized object is required here for stacks specifically. This
+ * isn't a requirement of elastipool, but of logic that initializes static thread stacks. Some
+ * architectures require a non-trivial stack size even if that stack is never used. This is more
+ * a quirk of the current static stack initialization logic and is unrelated to elastipool or
+ * actually running threads.
+ */
+static K_THREAD_STACK_DEFINE(z_unused_init_stack, CONFIG_IDLE_STACK_SIZE);
+#define SYS_THREAD_STACK_INIT(idx) ((k_thread_stack_t *)&z_unused_init_stack)
+#define SYS_THREAD_STACK_INIT_SIZE CONFIG_IDLE_STACK_SIZE
+#else
+/*
+ * Initializing stacks (for software stack overflow detection) requires filling them with a
+ * known pattern. This is normally used in testing, but can be used as well for runtime
+ * stack overflow detection (on cores that do not have hardware stack protection) or stack
+ * usage analysis. In that case, we _must_ have a stack to associate with each thread in
+ * the statically initialized pool.
+ */
+BUILD_ASSERT(SYS_THREAD_STACK_MIN >= SYS_THREAD_THREAD_MIN);
+extern struct z_thread_stack_element
+	sys_stack_pool[SYS_THREAD_STACK_MIN][K_THREAD_STACK_LEN(CONFIG_SYS_THREAD_STACK_SIZE)];
+#define SYS_THREAD_STACK_INIT(idx) ((k_thread_stack_t *)&sys_stack_pool[(idx)])
+#define SYS_THREAD_STACK_INIT_SIZE CONFIG_SYS_THREAD_STACK_SIZE
+#endif
+#else
+#define SYS_THREAD_STACK_INIT(idx) ((k_thread_stack_t *)z_main_stack)
+#define SYS_THREAD_STACK_INIT_SIZE CONFIG_MAIN_STACK_SIZE
+#endif
+
+/* For declaring an array of k_thread */
+#define K_THREAD_ARRAY_DEFINE_ELEM(idx, name)                                                      \
+	Z_THREAD_INITIALIZER(&name[idx], SYS_THREAD_STACK_INIT(idx), SYS_THREAD_STACK_INIT_SIZE,  \
+			     NULL, NULL, NULL, NULL, 0, 0, SYS_FOREVER_MS, name##idx)
+#define K_THREAD_ARRAY_DEFINE(name, num)                                                           \
+	__maybe_unused struct k_thread name[num];                                                  \
+	STRUCT_SECTION_ITERABLE_ARRAY(_static_thread_data, name##_data,                           \
+				      num) = {LISTIFY(num, K_THREAD_ARRAY_DEFINE_ELEM, (,), name) }
+
+#ifdef CONFIG_ZTEST
+static bool print_1pool_stats(const struct sys_elastipool *pool, const char *const name);
+#endif
+
+static void *heap_obj_allocator(void *obj, size_t size, enum k_objects otype, uint32_t flags);
+static void sys_thread_recycle(void);
+static void sys_thread_recycle_work_handler(struct k_work *work);
+static k_thread_stack_t *sys_thread_stack_obj(struct k_thread *thread);
+
+LOG_MODULE_REGISTER(sys_thread, CONFIG_SYS_THREAD_LOG_LEVEL);
+static K_WORK_DELAYABLE_DEFINE(sys_thread_recycle_work, sys_thread_recycle_work_handler);
+
+/* FIXME: should probably change the signature of sys_elastipool_api_heap_alloc_t so that
+ * the first argument is non-const */
+static inline void *cond_pool_heap_alloc(const void *ptr, size_t size, size_t align,
+					 uint32_t flags)
+{
+	return heap_obj_allocator((void *)ptr, size, K_OBJ_CONDVAR, flags);
+}
+
+static inline void *mutex_pool_heap_alloc(const void *ptr, size_t size, size_t align,
+					  uint32_t flags)
+{
+	return heap_obj_allocator((void *)ptr, size, K_OBJ_MUTEX, flags);
+}
+
+static inline void *stack_pool_heap_alloc(const void *ptr, size_t size, size_t align,
+					  uint32_t flags)
+{
+	return heap_obj_allocator((void *)ptr, size, K_OBJ_THREAD_STACK_ELEMENT, flags);
+}
+
+static inline void *thread_pool_heap_alloc(const void *ptr, size_t size, size_t align,
+					   uint32_t flags)
+{
+	return heap_obj_allocator((void *)ptr, size, K_OBJ_THREAD, flags);
+}
+
+static const char *const heap_obj_str(enum k_objects otype);
+
+BUILD_ASSERT(SYS_THREAD_CONDVAR_MIN >= 0);
+BUILD_ASSERT(CONFIG_SYS_THREAD_CONDVAR_MAX >= SYS_THREAD_CONDVAR_MIN);
+
+static struct k_spinlock cond_pool_lock;
+K_CONDVAR_ARRAY_DEFINE(sys_condvar_pool, SYS_THREAD_CONDVAR_MIN);
+SYS_ELASTIPOOL_DEFINE_ADVANCED(cond_pool, sizeof(struct k_condvar), __alignof(struct k_condvar),
+			       SYS_THREAD_CONDVAR_MIN, CONFIG_SYS_THREAD_CONDVAR_MAX,
+			       cond_pool_heap_alloc, sys_condvar_pool, static);
+
+BUILD_ASSERT(SYS_THREAD_MUTEX_MIN >= 0);
+BUILD_ASSERT(CONFIG_SYS_THREAD_MUTEX_MAX >= SYS_THREAD_MUTEX_MIN);
+
+static struct k_spinlock mutex_pool_lock;
+K_MUTEX_ARRAY_DEFINE(sys_mutex_pool, SYS_THREAD_MUTEX_MIN);
+SYS_ELASTIPOOL_DEFINE_ADVANCED(mutex_pool, sizeof(struct k_mutex), __alignof(struct k_mutex),
+			       SYS_THREAD_MUTEX_MIN, CONFIG_SYS_THREAD_MUTEX_MAX,
+			       mutex_pool_heap_alloc, sys_mutex_pool, static);
+
+BUILD_ASSERT(SYS_THREAD_STACK_MIN >= 0);
+BUILD_ASSERT(CONFIG_SYS_THREAD_STACK_MAX >= SYS_THREAD_STACK_MIN);
+
+static struct k_spinlock stack_pool_lock;
+K_THREAD_STACK_ARRAY_DEFINE(sys_stack_pool, SYS_THREAD_STACK_MIN, CONFIG_SYS_THREAD_STACK_SIZE);
+SYS_ELASTIPOOL_DEFINE_ADVANCED(stack_pool, K_THREAD_STACK_LEN(CONFIG_SYS_THREAD_STACK_SIZE),
+			       K_THREAD_STACK_ALIGN(CONFIG_SYS_THREAD_STACK_SIZE),
+			       SYS_THREAD_STACK_MIN, CONFIG_SYS_THREAD_STACK_MAX,
+			       stack_pool_heap_alloc, sys_stack_pool, static);
+
+BUILD_ASSERT(SYS_THREAD_THREAD_MIN >= 0);
+BUILD_ASSERT(CONFIG_SYS_THREAD_THREAD_MAX >= SYS_THREAD_THREAD_MIN);
+
+static struct k_spinlock thread_pool_lock;
+K_THREAD_ARRAY_DEFINE(sys_thread_pool, SYS_THREAD_THREAD_MIN);
+static sys_dlist_t thread_pool_free_list = SYS_DLIST_STATIC_INIT(&thread_pool_free_list);
+SYS_ELASTIPOOL_DEFINE_ADVANCED(thread_pool, sizeof(struct k_thread), __alignof(struct k_thread),
+			       SYS_THREAD_THREAD_MIN, CONFIG_SYS_THREAD_THREAD_MAX,
+			       thread_pool_heap_alloc, sys_thread_pool, static);
+
+int z_impl_sys_condvar_destroy(struct k_condvar *cond)
+{
+	if (CONFIG_SYS_THREAD_CONDVAR_MAX == 0) {
+		return 0;
+	}
+
+	int ret = -EINVAL;
+
+	K_SPINLOCK(&cond_pool_lock) {
+		if (sys_elastipool_check(&cond_pool, cond) != 0) {
+			ret = -EINVAL;
+			K_SPINLOCK_BREAK;
+		}
+
+		ret = sys_elastipool_free(&cond_pool, cond);
+	}
+
+	return ret;
+}
+
+#ifdef CONFIG_USERSPACE
+int z_vrfy_sys_condvar_destroy(struct k_condvar *cond)
+{
+	K_OOPS(K_SYSCALL_OBJ(cond, K_OBJ_CONDVAR));
+	return z_impl_sys_condvar_destroy(cond);
+}
+#include <zephyr/syscalls/sys_condvar_destroy_mrsh.c>
+#endif
+
+int z_impl_sys_condvar_init(struct k_condvar **cond)
+{
+	if (CONFIG_SYS_THREAD_CONDVAR_MAX == 0) {
+		LOG_WRN_ONCE("%s pool is disabled", heap_obj_str(K_OBJ_CONDVAR));
+		return -ENOTSUP;
+	}
+
+	int ret = -ENOMEM;
+
+	K_SPINLOCK(&cond_pool_lock) {
+		ret = sys_elastipool_alloc(&cond_pool, (void **)cond);
+	}
+
+	if (ret < 0) {
+		return ret;
+	}
+
+#ifdef CONFIG_USERSPACE
+	if (k_is_in_user_syscall()) {
+		extern int z_vrfy_k_condvar_init(struct k_condvar * cond);
+
+		/* do not skip checks in z_vrfy_k_condvar_init() due to z_syscall_trap() */
+		k_object_access_grant(*cond, _current);
+		ret = z_vrfy_k_condvar_init(*cond);
+	} else
+#endif
+	{
+		ret = k_condvar_init(*cond);
+	}
+	if (ret < 0) {
+		LOG_DBG("%s() failed: %d", "k_condvar_init", ret);
+		goto out;
+	}
+
+	if (IS_ENABLED(CONFIG_TEST) && (CONFIG_SYS_THREAD_CONDVAR_MAX == SYS_THREAD_CONDVAR_MIN)) {
+		__ASSERT_NO_MSG(IS_ARRAY_ELEMENT(sys_condvar_pool, *cond));
+	}
+
+out:
+	if (ret != 0) {
+		K_SPINLOCK(&cond_pool_lock) {
+			sys_elastipool_free(&cond_pool, *cond);
+		}
+	}
+
+	return ret;
+}
+
+#ifdef CONFIG_USERSPACE
+int z_vrfy_sys_condvar_init(struct k_condvar **cond)
+{
+	K_OOPS(K_SYSCALL_MEMORY_WRITE(cond, sizeof(*cond)));
+	return z_impl_sys_condvar_init(cond);
+}
+#include <zephyr/syscalls/sys_condvar_init_mrsh.c>
+#endif
+
+int z_impl_sys_mutex_destroy(struct k_mutex *mutex)
+{
+	if (CONFIG_SYS_THREAD_MUTEX_MAX == 0) {
+		return 0;
+	}
+
+	int ret = -EINVAL;
+
+	if (mutex->lock_count != 0) {
+		LOG_DBG("mutex %p is locked!", mutex);
+		return -EBUSY;
+	}
+
+	K_SPINLOCK(&mutex_pool_lock) {
+		if (sys_elastipool_check(&mutex_pool, mutex) != 0) {
+			ret = -EINVAL;
+			K_SPINLOCK_BREAK;
+		}
+
+		ret = sys_elastipool_free(&mutex_pool, mutex);
+	}
+
+	return ret;
+}
+
+#ifdef CONFIG_USERSPACE
+int z_vrfy_sys_mutex_destroy(struct k_mutex *mutex)
+{
+	K_OOPS(K_SYSCALL_OBJ(mutex, K_OBJ_MUTEX));
+	return z_impl_sys_mutex_destroy(mutex);
+}
+#include <zephyr/syscalls/sys_mutex_destroy_mrsh.c>
+#endif
+
+int z_impl_sys_mutex_init(struct k_mutex **mutex, uint32_t options)
+{
+	if (CONFIG_SYS_THREAD_MUTEX_MAX == 0) {
+		LOG_WRN_ONCE("%s pool is disabled", heap_obj_str(K_OBJ_MUTEX));
+		return -ENOTSUP;
+	}
+
+	int ret = -ENOMEM;
+
+	K_SPINLOCK(&mutex_pool_lock) {
+		ret = sys_elastipool_alloc(&mutex_pool, (void **)mutex);
+	}
+
+	if (ret < 0) {
+		return ret;
+	}
+
+#ifdef CONFIG_USERSPACE
+	if (k_is_in_user_syscall()) {
+		extern int z_vrfy_k_mutex_init_ext(struct k_mutex * mutex, uint32_t options);
+
+		/* do not skip checks in z_vrfy_k_mutex_init_ext() due to z_syscall_trap() */
+		k_object_access_grant(*mutex, _current);
+		ret = z_vrfy_k_mutex_init_ext(*mutex, options);
+	} else
+#endif
+	{
+		ret = k_mutex_init_ext(*mutex, options);
+	}
+
+	if (ret < 0) {
+		LOG_DBG("%s() failed: %d", "k_mutex_init_ext", ret);
+		goto out;
+	}
+
+	if (IS_ENABLED(CONFIG_TEST) && (CONFIG_SYS_THREAD_MUTEX_MAX == SYS_THREAD_MUTEX_MIN)) {
+		__ASSERT_NO_MSG(IS_ARRAY_ELEMENT(sys_mutex_pool, *mutex));
+	}
+
+out:
+	if (ret != 0) {
+		K_SPINLOCK(&mutex_pool_lock) {
+			sys_elastipool_free(&mutex_pool, *mutex);
+		}
+	}
+
+	return ret;
+}
+
+#ifdef CONFIG_USERSPACE
+int z_vrfy_sys_mutex_init(struct k_mutex **mutex, uint32_t options)
+{
+	K_OOPS(K_SYSCALL_MEMORY_WRITE(mutex, sizeof(*mutex)));
+	return z_impl_sys_mutex_init(mutex, options);
+}
+#include <zephyr/syscalls/sys_mutex_init_mrsh.c>
+#endif
+
+static void sys_thread_recycle_work_handler(struct k_work *work)
+{
+	ARG_UNUSED(work);
+
+	K_SPINLOCK(&thread_pool_lock) {
+		sys_thread_recycle();
+	}
+}
+
+static void sys_thread_recycle(void)
+{
+	while (!sys_dlist_is_empty(&thread_pool_free_list)) {
+		struct k_thread *thread = CONTAINER_OF(sys_dlist_get(&thread_pool_free_list),
+						       struct k_thread, base.sys_thread_free_node);
+		k_thread_stack_t *stack = sys_thread_stack_obj(thread);
+
+		if (!(z_is_thread_state_set(thread, _THREAD_DUMMY) ||
+		      z_is_thread_state_set(thread, _THREAD_DEAD))) {
+			LOG_DBG("Skipping tid %p since it is in use", thread);
+			sys_dlist_append(&thread_pool_free_list,
+					 &thread->base.sys_thread_free_node);
+			continue;
+		}
+
+		if (sys_elastipool_check(&thread_pool, thread) == 0) {
+			sys_elastipool_free(&thread_pool, thread);
+		}
+
+		if (stack != NULL) {
+			sys_elastipool_free(&stack_pool, stack);
+			/* disassociate stack from thread */
+			thread->stack_info.start = 0;
+		}
+	}
+}
+
+int z_impl_sys_thread_create(struct k_thread **th, k_thread_stack_t *stack, size_t size,
+			     k_thread_entry_t entry, void *p1, void *p2, void *p3, int prio,
+			     uint32_t options)
+{
+	int ret = -ENOMEM;
+
+	K_SPINLOCK(&thread_pool_lock) {
+		sys_thread_recycle();
+		ret = sys_elastipool_alloc(&thread_pool, (void **)th);
+	}
+
+	if (ret < 0) {
+		return ret;
+	}
+
+	if ((stack == NULL) && (size == 0)) {
+		size = CONFIG_SYS_THREAD_STACK_SIZE;
+		stack = k_thread_stack_alloc(size, options);
+		if (stack == NULL) {
+			K_SPINLOCK(&thread_pool_lock) {
+				(void)sys_elastipool_free(&thread_pool, *th);
+			}
+			return -ENOMEM;
+		}
+#ifdef CONFIG_USERSPACE
+		if (k_is_in_user_syscall()) {
+			k_object_access_grant(stack, *th);
+			k_object_access_grant(stack, _current);
+		}
+#endif
+	}
+
+#ifdef CONFIG_USERSPACE
+	if (k_is_in_user_syscall()) {
+		k_tid_t z_vrfy_k_thread_create(struct k_thread * new_thread, k_thread_stack_t * stack,
+					       size_t stack_size, k_thread_entry_t entry, void *p1,
+					       void *p2, void *p3, int prio, uint32_t options,
+					       k_timeout_t delay);
+
+		k_object_access_grant(*th, *th);
+		k_object_access_grant(*th, _current);
+		k_object_uninit(*th);
+		z_vrfy_k_thread_create(*th, stack, size, entry, p1, p2, p3, prio, options,
+				       K_NO_WAIT);
+		return 0;
+	}
+#endif
+
+	k_thread_create(*th, stack, size, entry, p1, p2, p3, prio, options, K_NO_WAIT);
+
+	return 0;
+}
+
+#ifdef CONFIG_USERSPACE
+int z_vrfy_sys_thread_create(struct k_thread **th, k_thread_stack_t *stack, size_t size,
+			     k_thread_entry_t entry, void *p1, void *p2, void *p3, int prio,
+			     uint32_t options)
+{
+	K_OOPS(K_SYSCALL_MEMORY_WRITE(th, sizeof(*th)));
+
+	/* user threads may only create other user threads and also must inherit permissions */
+	options |= K_USER | K_INHERIT_PERMS;
+
+	/* Further verification is performed in z_vrfy_k_thread_create() */
+	return z_impl_sys_thread_create(th, stack, size, entry, p1, p2, p3, prio, options);
+}
+#include <zephyr/syscalls/sys_thread_create_mrsh.c>
+#endif
+
+int z_impl_sys_thread_destroy(struct k_thread *th, bool now)
+{
+	if (CONFIG_SYS_THREAD_THREAD_MAX == 0) {
+		return 0;
+	}
+
+	bool schedule_work = false;
+
+	K_SPINLOCK(&thread_pool_lock) {
+		if (now) {
+			k_thread_stack_t *stack = sys_thread_stack_obj(th);
+
+			if (sys_elastipool_check(&thread_pool, th) == 0) {
+				sys_elastipool_free(&thread_pool, th);
+			}
+
+			if (stack != NULL) {
+				sys_elastipool_free(&stack_pool, stack);
+				/* disassociate stack from thread */
+				th->stack_info.start = 0;
+			}
+
+			K_SPINLOCK_BREAK;
+		}
+
+		sys_dlist_append(&thread_pool_free_list, &th->base.sys_thread_free_node);
+		schedule_work = true;
+	}
+
+	if (!schedule_work) {
+		return 0;
+	}
+
+	return k_work_schedule(&sys_thread_recycle_work,
+			       K_MSEC(CONFIG_SYS_THREAD_RECYCLER_DELAY_MS));
+}
+
+#ifdef CONFIG_USERSPACE
+int z_vrfy_sys_thread_destroy(struct k_thread *th, bool now)
+{
+	K_OOPS(K_SYSCALL_OBJ(th, K_OBJ_THREAD));
+	return z_impl_sys_thread_destroy(th, now);
+}
+#include <zephyr/syscalls/sys_thread_destroy_mrsh.c>
+#endif
+
+static inline const char *const heap_obj_str(enum k_objects otype)
+{
+	switch (otype) {
+	case K_OBJ_CONDVAR:
+		return "k_condvar";
+	case K_OBJ_MUTEX:
+		return "k_mutex";
+	case K_OBJ_THREAD_STACK_ELEMENT:
+		return "k_thread_stack_t";
+	case K_OBJ_THREAD:
+		return "k_thread";
+	default:
+		__ASSERT(false, "invalid object type %d", otype);
+	}
+
+	return "";
+}
+
+static void *heap_obj_allocator(void *obj, size_t size, enum k_objects otype, uint32_t flags)
+{
+	if (obj == NULL) {
+		/* allocate an object */
+
+		if (IS_ENABLED(CONFIG_DYNAMIC_OBJECTS)) {
+			switch (otype) {
+			case K_OBJ_CONDVAR:
+			case K_OBJ_MUTEX:
+			case K_OBJ_THREAD:
+				return k_object_alloc(otype);
+			case K_OBJ_THREAD_STACK_ELEMENT:
+#ifdef CONFIG_USERSPACE
+				if (k_is_in_user_syscall() || ((flags & K_USER) != 0)) {
+					return k_object_alloc_size(K_OBJ_THREAD_STACK_ELEMENT,
+								   size);
+				} else
+#endif
+				{
+					return z_thread_aligned_alloc(Z_KERNEL_STACK_OBJ_ALIGN,
+								      K_KERNEL_STACK_LEN(size));
+				}
+			default:
+				__ASSERT(false, "invalid object type %d", otype);
+				return NULL;
+			}
+		}
+
+		if (IS_ENABLED(CONFIG_USERSPACE) && k_is_user_context()) {
+			LOG_WRN_ONCE("CONFIG_DYNAMIC_OBJECTS is not enabled");
+			return NULL;
+		}
+
+		size_t align;
+
+		switch (otype) {
+		case K_OBJ_CONDVAR:
+			size = sizeof(struct k_condvar);
+			align = __alignof(struct k_condvar);
+			break;
+		case K_OBJ_MUTEX:
+			size = sizeof(struct k_mutex);
+			align = __alignof(struct k_mutex);
+			break;
+		case K_OBJ_THREAD:
+			size = sizeof(struct k_thread);
+			align = __alignof(struct k_thread);
+			break;
+		case K_OBJ_THREAD_STACK_ELEMENT:
+			size = K_KERNEL_STACK_LEN(size);
+			align = Z_KERNEL_STACK_OBJ_ALIGN;
+			break;
+		default:
+			__ASSERT(false, "invalid object type %d", otype);
+			return NULL;
+		}
+
+		return z_thread_aligned_alloc(align, size);
+	}
+
+	/* deallocate an object */
+	__ASSERT(size == 0, "freeing object with non-zero size");
+
+#ifdef CONFIG_USERSPACE
+	if (k_object_find(obj)) {
+		k_object_free(obj);
+	} else {
+		k_free((void *)obj);
+	}
+#else
+	k_free((void *)obj);
+#endif /* CONFIG_USERSPACE */
+
+	return NULL;
+}
+
+static k_thread_stack_t *sys_thread_stack_obj(struct k_thread *thread)
+{
+#ifdef CONFIG_USERSPACE
+	if (sys_elastipool_check(&stack_pool, thread->stack_obj) == 0) {
+		return thread->stack_obj;
+	}
+
+	return NULL;
+#else
+	k_thread_stack_t *stack;
+
+#ifdef CONFIG_THREAD_STACK_MEM_MAPPED
+	void *mapped_base = (void *)((char *)thread->stack_info.start - K_KERNEL_STACK_RESERVED);
+	uintptr_t phys;
+
+	if (arch_page_phys_get(mapped_base, &phys) == 0) {
+		stack = (k_thread_stack_t *)phys;
+		if (sys_elastipool_check(&stack_pool, stack) == 0) {
+			return stack;
+		}
+	}
+
+	if (thread->stack_info.mapped.addr != NULL) {
+		if (arch_page_phys_get(thread->stack_info.mapped.addr, &phys) == 0) {
+			stack = (k_thread_stack_t *)phys;
+			if (sys_elastipool_check(&stack_pool, stack) == 0) {
+				return stack;
+			}
+		}
+	}
+#endif
+
+	/* Architectures with reserved bytes before the stack buffer (x86/arm64). */
+	stack = (k_thread_stack_t *)((char *)thread->stack_info.start - K_KERNEL_STACK_RESERVED);
+	if (sys_elastipool_check(&stack_pool, stack) == 0) {
+		return stack;
+	}
+
+	/* Architectures where stack_info.start is the object base (no reserved prefix). */
+#if !defined(CONFIG_X86) && !defined(CONFIG_ARM64)
+	stack = (k_thread_stack_t *)thread->stack_info.start;
+	if (sys_elastipool_check(&stack_pool, stack) == 0) {
+		return stack;
+	}
+#endif
+
+	return NULL;
+#endif
+}
+
+#ifdef CONFIG_ZTEST
+#include <zephyr/ztest.h>
+static bool print_1pool_stats(const struct sys_elastipool *pool, const char *const name)
+{
+	if (pool->data->pool_size == 0) {
+		return false;
+	}
+	LOG_DBG("%s pool usage: %zu/%zu", name, pool->data->pool_size, pool->config->max_obj);
+	return true;
+}
+
+static void print_stats(const struct ztest_unit_test *test, void *data)
+{
+	ARG_UNUSED(test);
+	ARG_UNUSED(data);
+
+	if (test->stats->fail_count > 0) {
+		/* Skip leak checks for already-failing tests to avoid masking root cause. */
+		return;
+	}
+
+	bool leak = false;
+	int type[] = {K_OBJ_CONDVAR, K_OBJ_MUTEX, K_OBJ_THREAD_STACK_ELEMENT, K_OBJ_THREAD};
+	const struct sys_elastipool *const pool[] = {&cond_pool, &mutex_pool, &stack_pool,
+						     &thread_pool};
+
+	/* clean up before the sys workq does to avoid false positives */
+	K_SPINLOCK(&thread_pool_lock) {
+		sys_thread_recycle();
+	}
+
+	ARRAY_FOR_EACH(type, i) {
+		leak = print_1pool_stats(pool[i], heap_obj_str(type[i])) || leak;
+	}
+
+	/* This will assert if any tests leak objects */
+	__ASSERT(!leak, "object pool leak detected");
+}
+
+ZTEST_RULE(sys_thread_rule, NULL, print_stats);
+#endif /* CONFIG_ZTEST */
