+
+void z_impl_k_thread_exit(void *result)
+{
+	ARG_UNUSED(result);
+
+	int __maybe_unused ret;
+
+	/* disable cancellation temporarily */
+	k_thread_cancel_setstate(false);
+
+	/* cancel the thread. the request will pend until cancellation is re-enabled */
+	ret = k_thread_cancel(_current);
+	__ASSERT(ret == 0, "%s() failed: %d", "k_thread_cancel", ret);
+
+	/* override the K_THREAD_CANCELLED result with the user-provided result */
+	k_thread_result_set(result);
+
+	/* ensure that the correct signal action is in place */
+	ret = k_sig_action(K_SIG_CANCEL, K_SIG_DFL, NULL);
+	__ASSERT(ret == 0, "%s() failed: %d", "k_sig_action", ret);
+
+	/* re-enable cancellation */
+	k_thread_cancel_setstate(true);
+
+	/* failsafe */
+	k_thread_abort(_current);
+
+	CODE_UNREACHABLE;
+}
+
+#ifdef CONFIG_USERSPACE
+void z_vrfy_k_thread_exit(void *result)
+{
+	return z_impl_k_thread_exit(result);
+}
+#include <zephyr/syscalls/k_thread_exit_mrsh.c>
+#endif /* CONFIG_USERSPACE */
+#endif /* CONFIG_THREAD_CANCEL */
