diff --git a/include/zephyr/sys/zvfs_fs.h b/include/zephyr/sys/zvfs_fs.h
new file mode 100644
index 00000000000..ab1e1a60b52
--- /dev/null
+++ b/include/zephyr/sys/zvfs_fs.h
@@ -0,0 +1,72 @@
+/*
+ * SPDX-FileCopyrightText: Copyright The Zephyr Project Contributors
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#ifndef ZEPHYR_INCLUDE_SYS_ZVFS_FS_H_
+#define ZEPHYR_INCLUDE_SYS_ZVFS_FS_H_
+
+/**
+ * @file
+ * @brief ZVFS path open via the Zephyr file system.
+ *
+ * Provides zvfs_open(), which wraps Zephyr fs_open() and registers the result in
+ * the fd table. ISO C fopen() and POSIX open() both use this entry point; it is
+ * not part of the POSIX_FILE_SYSTEM option group.
+ */
+
+#include <stdbool.h>
+
+#include <zephyr/fs/fs.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/**
+ * @brief Backing object for a ZVFS file or directory stream on a mounted FS.
+ *
+ * Used by zvfs_open() for files (registered in the fd table) and by POSIX
+ * opendir() for directory streams (not fd-backed).
+ */
+struct zvfs_fs_desc {
+	union {
+		struct fs_file_t file;
+		struct fs_dir_t dir;
+	};
+	bool is_dir: 1;
+	bool used: 1;
+};
+
+/**
+ * @brief Open a path on a mounted Zephyr file system and return an fd.
+ *
+ * @param name Absolute path (as required by fs_open()).
+ * @param flags POSIX O_* open flags.
+ * @param mode File mode when O_CREAT is set.
+ *
+ * @return File descriptor on success, or -1 on error (errno is set).
+ */
+int zvfs_open(const char *name, int flags, int mode);
+
+/**
+ * @brief Allocate a ZVFS FS descriptor slot.
+ *
+ * @param is_dir True for a directory stream, false for a file object.
+ *
+ * @return Pointer to a descriptor, or NULL if the pool is exhausted.
+ */
+struct zvfs_fs_desc *zvfs_fs_desc_alloc(bool is_dir);
+
+/**
+ * @brief Return a ZVFS FS descriptor slot to the pool.
+ *
+ * @param ptr Descriptor previously returned by zvfs_fs_desc_alloc().
+ */
+void zvfs_fs_desc_free(struct zvfs_fs_desc *ptr);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* ZEPHYR_INCLUDE_SYS_ZVFS_FS_H_ */
diff --git a/include/zephyr/sys/zvfs_libc.h b/include/zephyr/sys/zvfs_libc.h
new file mode 100644
index 00000000000..1ad6c2fd656
--- /dev/null
+++ b/include/zephyr/sys/zvfs_libc.h
@@ -0,0 +1,123 @@
+/*
+ * SPDX-FileCopyrightText: Copyright The Zephyr Project Contributors
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#ifndef ZEPHYR_INCLUDE_SYS_ZVFS_LIBC_H_
+#define ZEPHYR_INCLUDE_SYS_ZVFS_LIBC_H_
+
+/**
+ * @file
+ * @brief ZVFS C library FILE<->fd binding hooks and backing store.
+ *
+ * The binding between a C library @c FILE and a ZVFS file descriptor can only be
+ * expressed in terms of each C library's stdio internals, so it lives inside the
+ * C library (not in generic Zephyr code - that is what made the old
+ * FILE-casting zvfs_fdopen()/zvfs_fileno() undefined behaviour). Each C library
+ * provides two mandatory, non-POSIX, ISO-C-only hooks:
+ *
+ * - zvfs_libc_fdopen()
+ * - zvfs_libc_fileno()
+ *
+ * Storage for the @c FILE comes from a generic, statically-allocated store
+ * (see lib/os/zvfs/zvfs_libc_file.c) that the hooks draw from. The dependency is
+ * strictly downward: POSIX -> libc hooks -> zvfs store; zvfs never calls up into
+ * the C library.
+ *
+ * @note This is the small header introduced alongside the FILE/fd fix; its
+ *       contents are intended to be folded into the consolidated zvfs.h later.
+ */
+
+#include <stddef.h>
+#include <stdio.h>
+
+#include <zephyr/kernel.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+#if defined(CONFIG_ZVFS_LIBC_FILE)
+
+/** @cond INTERNAL */
+#if CONFIG_ZVFS_LIBC_FILE_SIZE > 0
+#define ZVFS_LIBC_FILE_SIZE CONFIG_ZVFS_LIBC_FILE_SIZE
+#else
+#define ZVFS_LIBC_FILE_SIZE sizeof(*((FILE *)0))
+#endif
+
+#if CONFIG_ZVFS_LIBC_FILE_ALIGN > 0
+#define ZVFS_LIBC_FILE_ALIGN CONFIG_ZVFS_LIBC_FILE_ALIGN
+#else
+#define ZVFS_LIBC_FILE_ALIGN _Alignof(*((FILE *)0))
+#endif
+/** @endcond */
+
+#endif /* CONFIG_ZVFS_LIBC_FILE */
+
+/**
+ * @brief Associate a C library @c FILE with an open file descriptor.
+ *
+ * Implemented by each C library. The returned @c FILE is backed by the
+ * statically-allocated ZVFS FILE store (no dynamic allocation) and is released
+ * when the underlying descriptor is closed via @ref zvfs_close (e.g. through
+ * @c fclose() or @c close()).
+ *
+ * @param fd Open file descriptor.
+ * @param mode Mode string as passed to @c fopen()/fdopen().
+ *
+ * @return Pointer to a @c FILE on success, or NULL on error (errno is set).
+ */
+FILE *zvfs_libc_fdopen(int fd, const char *mode);
+
+/**
+ * @brief Return the file descriptor associated with a C library @c FILE.
+ *
+ * Implemented by each C library.
+ *
+ * @param fp A @c FILE previously returned by @ref zvfs_libc_fdopen (or a
+ *	     standard stream).
+ *
+ * @return The associated file descriptor, or -1 on error (errno is set).
+ */
+int zvfs_libc_fileno(FILE *fp);
+
+/**
+ * @brief Reserve a raw, uninitialized @c FILE-sized slot from the ZVFS store.
+ *
+ * Provided by the ZVFS store and called downward by a C library's
+ * @ref zvfs_libc_fdopen hook. The caller initializes the returned storage as a
+ * @c FILE using its own stdio internals. The slot is associated with @p fd so
+ * that it can be reclaimed when the descriptor is closed.
+ *
+ * @param fd Open file descriptor the slot will back.
+ * @param timeout Timeout to wait for a free slot.
+ *
+ * @return Pointer to @c ZVFS_LIBC_FILE_SIZE bytes of storage, or NULL if none
+ *	   is available.
+ */
+void *zvfs_libc_file_alloc(int fd, k_timeout_t timeout);
+
+/**
+ * @brief Return a previously allocated slot to the ZVFS store.
+ *
+ * Storage not owned by the store (e.g. standard streams) is silently ignored.
+ *
+ * @param fp Storage previously returned by @ref zvfs_libc_file_alloc.
+ */
+void zvfs_libc_file_free(void *fp);
+
+/**
+ * @brief Look up the store slot currently bound to @p fd.
+ *
+ * @param fd Open file descriptor.
+ *
+ * @return The bound storage, or NULL if none.
+ */
+void *zvfs_libc_file_from_fd(int fd);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* ZEPHYR_INCLUDE_SYS_ZVFS_LIBC_H_ */
