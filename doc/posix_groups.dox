/* -------------------------------------------------------------------------
 * POSIX Options
 * ------------------------------------------------------------------------- */

/**
 * @defgroup posix_option_asynchronous_io _POSIX_ASYNCHRONOUS_IO
 * @brief POSIX Asynchronous I/O option.
 */

/**
 * @defgroup posix_option_cputime _POSIX_CPUTIME
 * @brief POSIX CPU-Time Clocks option.
 */

/**
 * @defgroup posix_option_fsync _POSIX_FSYNC
 * @brief POSIX File Synchronization option.
 *
 * Covers @c fsync().
 */

/**
 * @defgroup posix_option_ipv6 _POSIX_IPV6
 * @brief POSIX IPv6 option.
 */

/**
 * @defgroup posix_option_memlock _POSIX_MEMLOCK
 * @brief POSIX Process Memory Locking option.
 */

/**
 * @defgroup posix_option_memlock_range _POSIX_MEMLOCK_RANGE
 * @brief POSIX Range Memory Locking option.
 */

/**
 * @defgroup posix_option_message_passing _POSIX_MESSAGE_PASSING
 * @brief POSIX Message Passing option (feature-test macro).
 *
 * When defined, indicates that message queue support is available. The @c mq_*()
 * APIs are documented under this option.
 */

/**
 * @defgroup posix_option_monotonic_clock _POSIX_MONOTONIC_CLOCK
 * @brief POSIX Monotonic Clock option.
 */

/**
 * @defgroup posix_option_priority_scheduling _POSIX_PRIORITY_SCHEDULING
 * @brief POSIX Priority Scheduling option.
 *
 * Covers process scheduling in @c sched.h: @c sched_get_priority_min(),
 * @c sched_get_priority_max(), @c sched_getparam(), @c sched_getscheduler(),
 * @c sched_setparam(), @c sched_setscheduler(), and @c sched_rr_get_interval().
 */

/**
 * @defgroup posix_option_thread_safe_functions _POSIX_THREAD_SAFE_FUNCTIONS
 * @brief POSIX Thread-Safe Functions option.
 *
 * In Zephyr, @c _POSIX_THREAD_SAFE_FUNCTIONS is defined when both
 * @c CONFIG_POSIX_C_LANG_SUPPORT_R and @c CONFIG_POSIX_FILE_SYSTEM_R are
 * enabled. Covers reentrant C library and file-system routines such as
 * @c asctime_r(), @c readdir_r(), and @c strerror_r().
 */

/**
 * @defgroup posix_option_raw_sockets _POSIX_RAW_SOCKETS
 * @brief POSIX Raw Sockets option.
 */

/**
 * @defgroup posix_option_shared_memory_objects _POSIX_SHARED_MEMORY_OBJECTS
 * @brief POSIX Shared Memory Objects option.
 */

/**
 * @defgroup posix_option_synchronized_io _POSIX_SYNCHRONIZED_IO
 * @brief POSIX Synchronized I/O option.
 *
 * Covers @c fdatasync().
 */

/**
 * @defgroup posix_option_thread_attr_stackaddr _POSIX_THREAD_ATTR_STACKADDR
 * @brief POSIX Thread Stack Address Attribute option.
