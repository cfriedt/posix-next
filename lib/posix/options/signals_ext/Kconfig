config POSIX_SIGNALS_EXT
	bool "Extended POSIX signal support"
	depends on POSIX_SIGNALS
	default y
	help
	  Enable strsignal() and related helpers from POSIX_SIGNALS_EXT.

if POSIX_SIGNALS_EXT

config POSIX_SIGNAL_STRING_DESC_DISABLE
	bool "Disable full description for the strsignal API"
	depends on !TC_PROVIDES_POSIX_SIGNALS_EXT
	help
	  When enabled, strsignal() returns "Signal N" instead of a human-readable
	  description. Saves approximately 256 bytes of ROM.

endif
