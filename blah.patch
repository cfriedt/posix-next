+k_thread_stack_t *z_impl_k_thread_stack_alloc(size_t size, uint32_t flags)
+{
+	if (CONFIG_SYS_THREAD_STACK_MAX == 0) {
+		LOG_WRN_ONCE("%s pool is disabled", heap_obj_str(K_OBJ_THREAD_STACK_ELEMENT));
+		return NULL;
+	}
+
+	int ret = -ENOMEM;
+	k_thread_stack_t *stack = NULL;
+
+	if (size > CONFIG_SYS_THREAD_STACK_SIZE) {
+		return NULL;
+	}
+
+	size = CONFIG_SYS_THREAD_STACK_SIZE;
+
+	K_SPINLOCK(&stack_pool_lock) {
+		ret = sys_elastipool_alloc_flags(&stack_pool, (void **)&stack, flags);
+	}
+
+	if (ret < 0) {
+		return NULL;
+	}
+
+	if (IS_ENABLED(CONFIG_TEST) && (CONFIG_SYS_THREAD_STACK_MAX == SYS_THREAD_STACK_MIN)) {
+		__ASSERT_NO_MSG(IS_ARRAY_ELEMENT(sys_stack_pool, stack));
+	}
+
+	return stack;
+}
