      "modules/lib/posix/tests/posix",
      "zephyr/tests/kernel/signal",
      "zephyr/tests/kernel/threads/thread_apis",
      "zephyr/tests/lib/c_lib",
      "zephyr/samples/net",
      "zephyr/tests/net"
    ],
    "args": [
      "--shuffle-tests"
    ]
  },
  "twister_nightly": {
    "shards": 10,
    "plan_args": [],
    "platforms": [
      "mps2/an385",
      "native_sim",
      "native_sim/native/64",
      "qemu_cortex_a53",
      "qemu_riscv32",
