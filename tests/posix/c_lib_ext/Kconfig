source "Kconfig.zephyr"
rsource "../Kconfig.test_common"

choice TEST_LOCALE_CHOICE
	prompt "Locale for strfmon tests"
	default TEST_LOCALE_CHOICE_C
	help
	  Choose the locale to be used for strfmon tests.

config TEST_LOCALE_CHOICE_C
	bool "Test locale C"
	help
	  Enable test using the C locale.

config TEST_LOCALE_CHOICE_EN_US_UTF8
	bool "Test locale en_US.UTF-8"
	help
	  Test using the en_US.UTF-8 locale.

endchoice

config TEST_LOCALE_STR
	string
	default "C" if TEST_LOCALE_CHOICE_C
	default "en_US.UTF-8" if TEST_LOCALE_CHOICE_EN_US_UTF8
	default "C"

# Minor hack since we already have CONFIG_TC_PROVIDES_POSIX_C_LIB_EXT for NATIVE_LIBC:
#
# since Kconfig.zephyr selects TC_PROVIDES_POSIX_C_LIB_EXT for NATIVE_LIBC, we explicitly
# disable it by default for testcases other than linux_compat. That way, the Zephyr
# implementation is also tested by native_sim.
#
# This can be easily verified by
#
# grep C_LIB_EXT twister-out/native_sim_native/host/modules/lib/posix/tests/posix/c_lib_ext/\
#   portability.posix.c_lib_ext.linux_compat/zephyr/.config
#   CONFIG_TC_PROVIDES_POSIX_C_LIB_EXT=y
#   CONFIG_POSIX_C_LIB_EXT=y
#
# grep C_LIB_EXT twister-out/native_sim_native/host/modules/lib/posix/tests/posix/c_lib_ext/\
#   portability.posix.c_lib_ext.picolibc/zephyr/.config
#   CONFIG_POSIX_C_LIB_EXT=n
config TC_PROVIDES_POSIX_C_LIB_EXT
	bool
	default y if TEST_POSIX_LINUX_COMPAT && ARCH_POSIX && CONFIG_NATIVE_LIBC
	default n
