+	}
+
+	K_OOPS(K_SYSCALL_MEMORY_WRITE(buf, sizeof(struct zvfs_stat)));
+
+	return z_impl_zvfs_fstat(fd, buf);
+}
+
+#include <zephyr/syscalls/zvfs_fstat_mrsh.c>
