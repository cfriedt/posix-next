diff --git a/lib/libc/newlib/include/sys/select.h b/lib/libc/newlib/include/sys/select.h
new file mode 100644
index 00000000000..488f718191f
--- /dev/null
+++ b/lib/libc/newlib/include/sys/select.h
@@ -0,0 +1,22 @@
+/*
+ * Copyright The Zephyr Project Contributors
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#ifndef ZEPHYR_LIB_LIBC_NEWLIB_INCLUDE_SYS_SELECT_H_
+#define ZEPHYR_LIB_LIBC_NEWLIB_INCLUDE_SYS_SELECT_H_
+
+/*
+ * Newlib's <sys/select.h> defines FD_CLR(), FD_ISSET(), FD_SET(), and
+ * FD_ZERO() as macros over a bit-array fd_set layout that does not match
+ * Zephyr's zvfs_fd_set. Pull in the newlib time types that its <sys/select.h>
+ * would normally include, then use the POSIX device I/O header for fd_set and
+ * the FD_* helpers.
+ */
+#include <sys/_timeval.h>
+#include <sys/timespec.h>
+
+#include <zephyr/posix/sys/select.h>
+
+#endif /* ZEPHYR_LIB_LIBC_NEWLIB_INCLUDE_SYS_SELECT_H_ */
