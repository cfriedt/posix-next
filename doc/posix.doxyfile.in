# SPDX-License-Identifier: Apache-2.0
# Doxygen configuration for posix-next.
# Headers ONLY — no .c sources are scanned.
# Variables with @NAME@ syntax are substituted by zephyr.doxyrunner.

DOXYFILE_ENCODING      = UTF-8

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------

PROJECT_NAME           = "posix-next API"
PROJECT_NUMBER         = @POSIX_NEXT_VERSION@
PROJECT_BRIEF          = "Out-of-tree Zephyr POSIX module"
PROJECT_LOGO           = @POSIX_NEXT_BASE@/doc/_static/posix-next-logo.png
PROJECT_ICON           = @ZEPHYR_BASE@/doc/_doxygen/favicon.png
OUTPUT_DIRECTORY       = @DOXY_OUT@

#---------------------------------------------------------------------------
# Input — public POSIX headers only; no .c files
#---------------------------------------------------------------------------

INPUT                  = @POSIX_NEXT_BASE@/include/zephyr/posix \
                         @POSIX_NEXT_BASE@/doc
FILE_PATTERNS          = *.h *.dox
RECURSIVE              = YES
INPUT_ENCODING         = UTF-8

# Exclude internal/private headers (underscore-prefixed = not part of POSIX ABI)
EXCLUDE_PATTERNS       = */posix_features.h \
                         */sys/_pthreadtypes.h

STRIP_FROM_PATH        = @POSIX_NEXT_BASE@/include
STRIP_FROM_INC_PATH    = @POSIX_NEXT_BASE@/include

#---------------------------------------------------------------------------
# Build
#---------------------------------------------------------------------------

EXTRACT_ALL            = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = YES
INLINE_INHERITED_MEMB  = YES
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
TAB_SIZE               = 4
OPTIMIZE_OUTPUT_FOR_C  = YES

ALIASES  = "retval{2}=@par Return values\n<dl><dt>\1</dt><dd>\2</dd></dl>"

# Typedef guard macros (e.g. _CLOCKID_T_DECLARED, __clockid_t_defined) are
# implementation details and clutter the generated macro lists.
EXCLUDE_SYMBOLS        = *_DECLARED \
                         *_defined

#---------------------------------------------------------------------------
# Preprocessor — expand guards so __DOXYGEN__-gated symbols are visible
#---------------------------------------------------------------------------

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             = __DOXYGEN__=1 \
                         _POSIX_C_SOURCE=200809L \
                         _XOPEN_SOURCE=700 \
                         _BSD_SOURCE=1 \
                         __cplusplus=0

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

#---------------------------------------------------------------------------
# Output formats
#---------------------------------------------------------------------------

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html

GENERATE_XML           = YES
XML_OUTPUT             = xml

GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO

#---------------------------------------------------------------------------
# HTML styling — reuse Zephyr doxygen-awesome theme
#---------------------------------------------------------------------------

GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO

HTML_HEADER            = @ZEPHYR_BASE@/doc/_doxygen/header.html
HTML_EXTRA_STYLESHEET  = @ZEPHYR_BASE@/doc/_doxygen/doxygen-awesome.css \
                         @ZEPHYR_BASE@/doc/_doxygen/doxygen-awesome-sidebar-only.css \
                         @ZEPHYR_BASE@/doc/_doxygen/doxygen-awesome-sidebar-only-darkmode-toggle.css \
                         @ZEPHYR_BASE@/doc/_doxygen/doxygen-awesome-zephyr.css \
                         @POSIX_NEXT_BASE@/doc/_doxygen/posix-next.css
HTML_EXTRA_FILES       = @ZEPHYR_BASE@/doc/_doxygen/doxygen-awesome-darkmode-toggle.js \
                         @ZEPHYR_BASE@/doc/_doxygen/doxygen-awesome-zephyr.js

#---------------------------------------------------------------------------
# Source browsing
#---------------------------------------------------------------------------

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
