+if(CONFIG_SYS_THREAD)
+  foreach(_pool CONDVAR MUTEX STACK THREAD)
+    # Sum CONFIG_SYS_THREAD_${_pool}_MIN with any CONFIG_SYS_THREAD_${_pool}_MIN_ADD_* additions
