-
-		ret = 0;
-		t->attr.cancelpending = true;
-		cancel_state = t->attr.cancelstate;
-		cancel_type = t->attr.canceltype;
-	}
-
-	if (ret == 0 && cancel_state == PTHREAD_CANCEL_ENABLE &&
-	    cancel_type == PTHREAD_CANCEL_ASYNCHRONOUS) {
