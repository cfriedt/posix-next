      "zephyr/samples/subsys/shell/shell_module",
      "zephyr/tests/kernel/signal",
      "zephyr/tests/kernel/threads/thread_apis",
      "zephyr/tests/lib/c_lib",
      "zephyr/tests/net"
    ],
    "args": [
      "--retry-failed", "3",
      "--shuffle-tests",
      "--runtime-artifact-cleanup",
      "-xCONFIG_TEST_EXTRA_STACK_SIZE=4096"
    ]
  },
  "coverage_nightly": {
    "shards": 10,
    "config_failure_ratio": 0.5,
    "shard_failure_ratio": 0,
    "plan_args": [],
    "platforms": [
      "mps2/an385",
      "native_sim",
      "qemu_x86"
    ],
    "roots": [
      "modules/lib/posix/samples/posix",
      "modules/lib/posix/tests/posix",
      "zephyr/samples/net",
      "zephyr/tests/kernel/signal",
      "zephyr/tests/kernel/threads/thread_apis",
      "zephyr/tests/lib/c_lib",
      "zephyr/tests/net"
    ],
    "args": [
      "--coverage",
      "--coverage-basedir", ".",
      "--coverage-per-instance",
      "--coverage-tool", "gcovr",
      "--filter", "runnable",
      "--timeout-multiplier", "2",
      "-e", "nano",
      "-e", "smp",
      "-xCONFIG_MP_MAX_NUM_CPUS=1",
      "-xCONFIG_MAIN_STACK_SIZE=24576",
      "-xCONFIG_NET_MGMT_EVENT_STACK_SIZE=24576",
      "-xCONFIG_NET_RX_STACK_SIZE=24576",
      "-xCONFIG_NET_TX_STACK_SIZE=24576",
      "-xCONFIG_NET_SOCKETS_SERVICE_STACK_SIZE=24576",
      "-xCONFIG_NET_TCP_WORKQ_STACK_SIZE=24576",
      "-xCONFIG_NET_L2_PPP_TX_STACK_SIZE=8192",
      "-xCONFIG_SYSTEM_WORKQUEUE_STACK_SIZE=24576",
      "-xCONFIG_HTTP_SERVER_STACK_SIZE=24576",
      "-xCONFIG_SHELL_STACK_SIZE=24576",
      "-xCONFIG_LWM2M_ENGINE_STACK_SIZE=24576",
      "-xCONFIG_NET_CONNECTION_MANAGER_MONITOR_STACK_SIZE=8192",
      "-xCONFIG_IDLE_STACK_SIZE=4096",
      "-xCONFIG_ISR_STACK_SIZE=4096",
      "-xCONFIG_PRIVILEGED_STACK_SIZE=24576",
      "-xCONFIG_TEST_EXTRA_STACK_SIZE=24576",
      "-xCONFIG_ZTEST_STACK_SIZE=24576",
      "-xEXTRA_CFLAGS=-fprofile-update=single -Wno-error=uninitialized"
    ]
  },
