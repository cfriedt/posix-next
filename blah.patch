new file mode 100644
index 00000000000..c5b353ea308
--- /dev/null
+++ b/arch/x86/core/eh_frame_register.c
@@ -0,0 +1,27 @@
+/*
+ * Copyright (c) 2026
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include <zephyr/init.h>
+#include <stdint.h>
+
+/* Provided by the linker script when C++ unwind tables are present. */
+extern char __eh_frame_start[];
+
+/* Provided by libgcc unwinder; keep weak so feature degrades safely. */
+extern void __register_frame(void *begin) __attribute__((weak));
+
+static int z_x86_register_eh_frame(void)
+{
+	uintptr_t eh_frame_start = (uintptr_t)__eh_frame_start;
+
+	if ((__register_frame != NULL) && (eh_frame_start != 0U)) {
+		__register_frame(__eh_frame_start);
+	}
+
+	return 0;
+}
+
+SYS_INIT(z_x86_register_eh_frame, POST_KERNEL, CONFIG_KERNEL_INIT_PRIORITY_DEFAULT);
