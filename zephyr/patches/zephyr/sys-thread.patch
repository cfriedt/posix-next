+common:
+  tags:
+    - kernel
+  min_ram: 64
+
+tests:
+  kernel.threads.sys_thread:
+    integration_platforms:
+      - native_sim
+      - qemu_x86
+      - qemu_x86/atom/nommu
+      - qemu_x86_64
+      - qemu_cortex_a53
+      - qemu_cortex_a53/qemu_cortex_a53/smp
+      - qemu_cortex_m3
+      - qemu_riscv32
+      - qemu_riscv32e
+      - qemu_riscv64
+      - qemu_riscv64/qemu_virt_riscv64/smp
+
+  kernel.threads.sys_thread.userspace:
+    filter: ARCH_HAS_USERSPACE
+    # skip x86* here because of the extremely large guard regions required
+    # See tests/kernel/threads/dynamic_thread_stack for those platforms.
+    # Probably should have an elastipool option that uses paged memory and
+    # make that the default on systems with paged memory.
+    platform_exclude:
+      - qemu_x86
+      - qemu_x86/atom/nommu
+      - qemu_x86_64
+    integration_platforms:
+      - qemu_cortex_a53
+      - qemu_cortex_a53/qemu_cortex_a53/smp
+      - qemu_cortex_m3
+      - qemu_riscv32
+      - qemu_riscv32e
+      - qemu_riscv64
+      - qemu_riscv64/qemu_virt_riscv64/smp
+    extra_configs:
+      - CONFIG_USERSPACE=y
+      - CONFIG_TEST_USERSPACE=y
