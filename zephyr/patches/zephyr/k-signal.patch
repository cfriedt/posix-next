+{
+	if (k_is_in_isr()) {
+		return -EFAULT;
+	}
+
+	K_SPINLOCK(k_sig_lock) {
+		z_sig_pending_unlocked(set, _current);
+	}
+
+	return 0;
+}
+
+#ifdef CONFIG_USERSPACE
+int z_vrfy_k_sig_pending(struct k_sig_set *set)
+{
+	K_OOPS(K_SYSCALL_MEMORY_WRITE(set, sizeof(*set)));
+	return z_impl_k_sig_pending(set);
+}
