-	case FNM_CC5('d', 'i', 'g', 'i', 't'):
-		ret = !isdigit(ch);
-		break;
-	case FNM_CC5('g', 'r', 'a', 'p', 'h'):
-		ret = !isgraph(ch);
-		break;
-	case FNM_CC5('l', 'o', 'w', 'e', 'r'):
-		ret = !islower(ch);
-		break;
-	case FNM_CC5('p', 'r', 'i', 'n', 't'):
-		ret = !isprint(ch);
-		break;
-	case FNM_CC5('p', 'u', 'n', 'c', 't'):
