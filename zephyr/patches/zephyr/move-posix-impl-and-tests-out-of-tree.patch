-	 * getentropy() uses size_t to represent buffer size, but Zephyr uses
-	 * uint16_t. The length check above allows us to safely cast without
-	 * overflow.
-	 */
-	if (entropy_get_entropy(entropy, buffer, (uint16_t)length)) {
-		errno = EIO;
-		return -1;
-	}
-
-	return 0;
-}
