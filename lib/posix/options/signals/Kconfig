menu "POSIX signals"

config POSIX_SIGNALS
	bool "POSIX signals"
	select SIGNAL
	select POSIX_MULTI_PROCESS
	help
	  Enable support for POSIX signals.

if POSIX_SIGNALS

config SIGNAL_SET_SIZE_MIN_POSIX
	def_int 32
	help
	  This number of signals required for POSIX conformance.

	  When enabled, this option ensures the value of SIGNAL_SET_SIZE is at least 32.

config SIGNAL_QUEUE_SIZE_ADD_POSIX
	def_int 4
	help
	  Number of signal queue entries required by the POSIX signals option group, which needs
	  room for signals generated by alarm(), kill(), and raise().

config SIGNAL_ACTION_DB_SIZE_MIN_POSIX
	def_int 8
	help
	  Number of signal action database entries required by the POSIX signals option group, so
	  that sigaction() and signal() can install handlers without SIGNAL_ACTION_DB_SIZE having to
	  be configured by hand.

	  When enabled, this option ensures the value of SIGNAL_ACTION_DB_SIZE is at least 8.

# These options are intended to be used for compatibility with external POSIX
# implementations such as those in Newlib or Picolibc.

config POSIX_SIGNALS_ALIAS_KILL
	bool

endif

endmenu # "Signal support"
