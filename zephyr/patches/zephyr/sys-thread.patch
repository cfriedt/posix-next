+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include <zephyr/kernel.h>
+#include <zephyr/sys/thread.h>
+#include <zephyr/ztest.h>
+
+/* --------------------------------------------------------------------------
+ * condvar pool tests
+ * -------------------------------------------------------------------------- */
+
+ZTEST(sys_thread_suite, test_condvar_init_destroy)
+{
+	struct k_condvar *cv = NULL;
+
+	zassert_ok(sys_condvar_init(&cv), "sys_condvar_init failed");
+	zassert_not_null(cv, "condvar pointer is NULL after init");
+	zassert_ok(sys_condvar_destroy(cv), "sys_condvar_destroy failed");
+}
+
+ZTEST(sys_thread_suite, test_condvar_pool_exhaustion)
+{
+	/* CONFIG_SYS_THREAD_CONDVAR_MAX=4; allocate all, then expect -ENOMEM */
+	struct k_condvar *cv[CONFIG_SYS_THREAD_CONDVAR_MAX + 1];
+	int i;
+
+	for (i = 0; i < CONFIG_SYS_THREAD_CONDVAR_MAX; i++) {
+		zassert_ok(sys_condvar_init(&cv[i]), "alloc %d failed", i);
+	}
+
+	zassert_equal(-ENOMEM, sys_condvar_init(&cv[i]),
+		      "expected -ENOMEM when pool exhausted");
+
+	/* clean up */
+	for (i = 0; i < CONFIG_SYS_THREAD_CONDVAR_MAX; i++) {
+		zassert_ok(sys_condvar_destroy(cv[i]));
+	}
+}
+
+/* --------------------------------------------------------------------------
+ * mutex pool tests
+ * -------------------------------------------------------------------------- */
+
+ZTEST(sys_thread_suite, test_mutex_init_destroy)
+{
+	struct k_mutex *m = NULL;
+
+	zassert_ok(sys_mutex_init(&m, 0), "sys_mutex_init failed");
+	zassert_not_null(m, "mutex pointer is NULL after init");
+	zassert_ok(sys_mutex_destroy(m), "sys_mutex_destroy failed");
+}
+
+ZTEST(sys_thread_suite, test_mutex_destroy_while_locked)
+{
+	struct k_mutex *m = NULL;
+
+	zassert_ok(sys_mutex_init(&m, 0));
+	zassert_ok(k_mutex_lock(m, K_NO_WAIT));
+	zassert_equal(-EBUSY, sys_mutex_destroy(m));
+	zassert_ok(k_mutex_unlock(m));
+	zassert_ok(sys_mutex_destroy(m));
+}
+
+ZTEST(sys_thread_suite, test_mutex_pool_exhaustion)
+{
+	struct k_mutex *m[CONFIG_SYS_THREAD_MUTEX_MAX + 1];
+	int i;
+
+	for (i = 0; i < CONFIG_SYS_THREAD_MUTEX_MAX; i++) {
+		zassert_ok(sys_mutex_init(&m[i], 0), "alloc %d failed", i);
+	}
+
+	zassert_equal(-ENOMEM, sys_mutex_init(&m[i], 0),
+		      "expected -ENOMEM when pool exhausted");
+
+	for (i = 0; i < CONFIG_SYS_THREAD_MUTEX_MAX; i++) {
+		zassert_ok(sys_mutex_destroy(m[i]));
+	}
+}
+
+/* --------------------------------------------------------------------------
+ * thread pool tests
+ * -------------------------------------------------------------------------- */
+
+static void thread_entry(void *p1, void *p2, void *p3)
+{
+	ARG_UNUSED(p1);
+	ARG_UNUSED(p2);
+	ARG_UNUSED(p3);
+}
+
+ZTEST(sys_thread_suite, test_thread_create_destroy)
+{
+	struct k_thread *th = NULL;
+	int ret;
+
+	ret = sys_thread_create(&th, NULL, 0, thread_entry, NULL, NULL, NULL,
+				K_LOWEST_APPLICATION_THREAD_PRIO, 0);
+	zassert_ok(ret, "sys_thread_create failed: %d", ret);
+	zassert_not_null(th, "thread pointer is NULL after create");
+
+	zassert_ok(k_thread_join(th, K_FOREVER), "k_thread_join failed");
+	zassert_ok(sys_thread_destroy(th, true), "sys_thread_destroy failed");
+}
+
+ZTEST(sys_thread_suite, test_thread_pool_exhaustion)
+{
+	struct k_thread *th[CONFIG_SYS_THREAD_THREAD_MAX + 1];
+	int i, ret;
+
+	/* Suspend self so the test threads don't immediately run and disappear */
+	for (i = 0; i < CONFIG_SYS_THREAD_THREAD_MAX; i++) {
+		ret = sys_thread_create(&th[i], NULL, 0, thread_entry, NULL, NULL, NULL,
+					K_LOWEST_APPLICATION_THREAD_PRIO,
+					K_INHERIT_PERMS);
+		zassert_ok(ret, "alloc %d failed: %d", i, ret);
+	}
+
+	ret = sys_thread_create(&th[i], NULL, 0, thread_entry, NULL, NULL, NULL,
+				K_LOWEST_APPLICATION_THREAD_PRIO, 0);
+	zassert_equal(-ENOMEM, ret, "expected -ENOMEM when pool exhausted");
+
+	for (i = 0; i < CONFIG_SYS_THREAD_THREAD_MAX; i++) {
+		k_thread_join(th[i], K_FOREVER);
+		sys_thread_destroy(th[i], true);
+	}
+}
+
+/* --------------------------------------------------------------------------
+ * suite setup / teardown
+ * -------------------------------------------------------------------------- */
+
+static void *setup(void)
+{
+	return NULL;
+}
+
+ZTEST_SUITE(sys_thread_suite, NULL, setup, NULL, NULL, NULL);
