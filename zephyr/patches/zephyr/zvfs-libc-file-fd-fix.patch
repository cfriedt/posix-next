+{
+	ARG_UNUSED(arg);
+
+	(void)fs_unlink(TEST_FILE);
 	zassert_ok(fs_unmount(&fatfs_mnt), "Error while unmount file system\n");
 }
+
+ZTEST_SUITE(libc_stdio, NULL, NULL, before, after, NULL);
