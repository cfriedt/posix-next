diff --git a/tests/kernel/threads/sys_thread/src/main.c b/tests/kernel/threads/sys_thread/src/main.c
new file mode 100644
index 00000000000..cf8a3383990
--- /dev/null
+++ b/tests/kernel/threads/sys_thread/src/main.c
@@ -0,0 +1,92 @@
+/*
+ * Copyright (c) 2026, Friedt Professional Engineering Services, Inc
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include <zephyr/kernel.h>
+#include <zephyr/sys/thread.h>
+#include <zephyr/ztest.h>
+
+
+ZTEST_USER(sys_thread, test_condvar_pool)
+{
+	int i;
+	struct k_condvar *cv[SYS_THREAD_CONDVAR_MIN + 1];
+
+	for (i = 0; i < SYS_THREAD_CONDVAR_MIN; ++i) {
+		zassert_ok(sys_condvar_alloc(&cv[i], 0));
+	}
+
+	if (CONFIG_SYS_THREAD_CONDVAR_MAX == SYS_THREAD_CONDVAR_MIN) {
+		/* if min and max are the same, only statically allocated condvars are in the pool */
+		zassert_equal(-ENOMEM, sys_condvar_alloc(&cv[i], 0));
+	} else {
+		/* allocate one more from the heap */
+		zassert_ok(sys_condvar_alloc(&cv[i], 0));
+		++i;
+	}
+
+	for (--i; i >= 0; --i) {
+		zassert_ok(sys_condvar_destroy(cv[i]));
+	}
+}
+
+ZTEST_USER(sys_thread, test_mutex_pool)
+{
+	int i;
+	struct k_mutex *m[SYS_THREAD_MUTEX_MIN + 1];
+
+	for (i = 0; i < SYS_THREAD_MUTEX_MIN; ++i) {
+		zassert_ok(sys_mutex_alloc(&m[i], 0));
+	}
+
+	if (CONFIG_SYS_THREAD_MUTEX_MAX == SYS_THREAD_MUTEX_MIN) {
+		/* if min and max are the same, only statically allocated mutexes are in the pool */
+		zassert_equal(-ENOMEM, sys_mutex_alloc(&m[i], 0));
+	} else {
+		/* allocate one more from the heap */
+		zassert_ok(sys_mutex_alloc(&m[i], 0));
+		++i;
+	}
+
+	for (--i; i >= 0; --i) {
+		zassert_ok(sys_mutex_destroy(m[i]));
+	}
+}
+
+static void thread_entry(void *p1, void *p2, void *p3)
+{
+	ARG_UNUSED(p1);
+	ARG_UNUSED(p2);
+	ARG_UNUSED(p3);
+}
+
+ZTEST_USER(sys_thread, test_thread_pool)
+{
+	int i;
+	struct k_thread *th[SYS_THREAD_THREAD_MIN + 1];
+
+	for (i = 0; i < SYS_THREAD_THREAD_MIN; ++i) {
+		zassert_ok(sys_thread_create(&th[i], NULL, 0, thread_entry, NULL, NULL, NULL,
+					K_LOWEST_APPLICATION_THREAD_PRIO,
+					K_INHERIT_PERMS));
+	}
+
+	if (CONFIG_SYS_THREAD_THREAD_MAX == SYS_THREAD_THREAD_MIN) {
+		/* if min and max are the same, only statically allocated threads are in the pool */
+		zassert_equal(-ENOMEM, sys_thread_create(&th[i], NULL, 0, thread_entry, NULL, NULL, NULL,
+					K_LOWEST_APPLICATION_THREAD_PRIO, 0));
+	} else {
+		/* allocate one more from the heap */
+		zassert_ok(sys_thread_create(&th[i], NULL, 0, thread_entry, NULL, NULL, NULL,
+					K_LOWEST_APPLICATION_THREAD_PRIO, 0));
+		++i;
+	}
+
+	for (--i; i >= 0; --i) {
+		zassert_ok(k_thread_join(th[i], K_FOREVER));
+	}
+}
+
+ZTEST_SUITE(sys_thread, NULL, NULL, NULL, NULL, NULL);
