diff --git a/lib/os/CMakeLists.txt b/lib/os/CMakeLists.txt
index 09ef3c4e4c0..eaf6ec021a5 100644
--- a/lib/os/CMakeLists.txt
+++ b/lib/os/CMakeLists.txt
