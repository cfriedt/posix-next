+int z_impl_zsock_sockatmark(int sock)
+{
+	const struct socket_op_vtable *vtable;
+	struct k_mutex *lock;
+	void *ctx;
+
+	ctx = get_sock_vtable(sock, &vtable, &lock);
+	if (ctx == NULL) {
+		errno = EBADF;
+		return -1;
+	}
+
+	ARG_UNUSED(vtable);
+	ARG_UNUSED(lock);
+
+	errno = ENOSYS;
+	return -1;
+}
+
+#ifdef CONFIG_USERSPACE
+static inline int z_vrfy_zsock_sockatmark(int sock)
+{
+	return z_impl_zsock_sockatmark(sock);
+}
+#include <zephyr/syscalls/zsock_sockatmark_mrsh.c>
+#endif /* CONFIG_USERSPACE */
