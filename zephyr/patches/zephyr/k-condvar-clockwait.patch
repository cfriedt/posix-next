diff --git a/include/zephyr/sys/clock.h b/include/zephyr/sys/clock.h
index 34f490dc642..b46de7fe835 100644
--- a/include/zephyr/sys/clock.h
+++ b/include/zephyr/sys/clock.h
@@ -373,6 +373,13 @@ static inline bool sys_timepoint_expired(k_timepoint_t timepoint)
  */
 #define SYS_CLOCK_MONOTONIC 4
 
+/**
+ * @brief A mask useful for selecting a clock from the SYS_CLOCK_MASK family.
+ *
+ * This mask can be used to select a clock from the SYS_CLOCK_MASK family.
+ */
+ #define SYS_CLOCK_MASK BIT_MASK(3)
+
 /**
