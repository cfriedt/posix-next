-		break;
-	case FNM_CC5('s', 'p', 'a', 'c', 'e'):
-		ret = !isspace(ch);
-		break;
-	case FNM_CC5('u', 'p', 'p', 'e', 'r'):
-		ret = !isupper(ch);
-		break;
