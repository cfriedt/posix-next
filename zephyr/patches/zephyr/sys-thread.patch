 		 * unchanged.  Disabled for posix as that arch
@@ -1382,6 +1389,9 @@ static void z_thread_epilogue(struct k_thread *thread, void **result, bool now)
 		*result = (void *)atomic_get(&thread->base.result);
 	}
 #endif
+#ifdef CONFIG_SYS_THREAD
+	sys_thread_destroy(thread, now);
+#endif
 }
 
 int z_impl_k_thread_rejoin(struct k_thread *thread, void **result, k_timeout_t timeout)
