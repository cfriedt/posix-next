 	int ret;
 	bool do_epilogue = false;
@@ -1413,7 +1428,7 @@ int z_impl_k_thread_rejoin(struct k_thread *thread, void **result, k_timeout_t t
 		SYS_PORT_TRACING_OBJ_FUNC_BLOCKING(k_thread, join, thread, timeout);
