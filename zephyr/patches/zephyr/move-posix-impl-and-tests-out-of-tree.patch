-ZTEST(xsi_threads_ext, test_pthread_attr_getstacksize)
-{
-	size_t stacksize = BIOS_FOOD;
-
-	/* degenerate cases */
-	{
-		if (false) {
-			/* undefined behaviour */
-			zassert_equal(pthread_attr_getstacksize(NULL, NULL), EINVAL);
