+	const int oret = k_object_validate(ko, K_OBJ_THREAD, _OBJ_INIT_TRUE);
+
+	if (oret == -EINVAL) {
+		return -ESRCH;
+	}
+
+	K_OOPS(K_SYSCALL_VERIFY_MSG(oret == 0, "access denied"));
+
+	return z_impl_k_thread_cancel(tid);
+}
