diff --git a/arch/arm64/core/signal.c b/arch/arm64/core/signal.c
new file mode 100644
index 00000000000..985be299ecb
--- /dev/null
+++ b/arch/arm64/core/signal.c
@@ -0,0 +1,46 @@
+/*
+ * Copyright (c) 2026, Friedt Professional Engineering Services, Inc.
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include <zephyr/kernel.h>
+
+extern void z_sig_trampoline(void);
+
+void arch_sig_pre(struct k_thread *thread, void *arg)
+{
+	struct arch_esf *const esf = arg;
+	struct arch_sig_ctx *const backup = &thread->base.sig.user;
+
+	/* Backup the original FP, SP, ELR (return address), and X0 (syscall return value) from PSF */
+#ifdef CONFIG_FRAME_POINTER
+	backup->fp = esf->fp;
+#endif
+#ifdef CONFIG_ARM64_SAFE_EXCEPTION_STACK
+	backup->sp = esf->sp;
+#endif
+	backup->lr = esf->lr;
+	backup->elr = esf->elr;
+	backup->x0 = esf->x0;
+
+	/* Overwrite PC (return address) to resume execution in arch_sig_trampoline() */
+	esf->elr = (unsigned long)arch_sig_trampoline;
+}
+
+void arch_sig_post(struct k_thread *thread, void *arg)
+{
+	struct arch_esf *const esf = arg;
+	struct arch_sig_ctx *const backup = &thread->base.sig.user;
+
+	/* Backup the original FP, SP, ELR (return address), and X0 (syscall return value) from PSF */
+#ifdef CONFIG_FRAME_POINTER
+	esf->fp = backup->fp;
+#endif
+#ifdef CONFIG_ARM64_SAFE_EXCEPTION_STACK
+	esf->sp = backup->sp;
+#endif
+	esf->lr = backup->lr;
+	esf->elr = backup->elr;
+	esf->x0 = backup->x0;
+}
diff --git a/arch/arm64/core/userspace.S b/arch/arm64/core/userspace.S
index 968d2a436bc..9c3198bd544 100644
--- a/arch/arm64/core/userspace.S
+++ b/arch/arm64/core/userspace.S
@@ -14,6 +14,10 @@

 _ASM_FILE_PROLOGUE

+#if defined(CONFIG_SIGNAL)
+GTEXT(z_sig_handle)
+#endif
+
 /*
  * size_t arch_user_string_nlen(const char *s, size_t maxsize, int *err_arg)
  */
@@ -124,5 +128,53 @@ valid_syscall_id:
 	/* Save the return value into the ESF */
 	str	x0, [sp, ___esf_t_x0_x1_OFFSET]

+#ifdef CONFIG_SIGNAL
+	ldr	x0, =K_SYSCALL_K_SIG_ACTION
+	cmp	x0, x8
+	beq skip_k_sig_handle
+	ldr	x0, =K_SYSCALL_K_SIG_CURRENT
+	cmp	x0, x8
+	beq skip_k_sig_handle
+	ldr	x0, =K_SYSCALL_K_SIG_RETURN
+	cmp	x0, x8
+	beq z_sig_return_restore
+
+	mov	x0, sp
+	ldr	x9, =z_sig_handle
+	blr	x9
+	cbz	x0, skip_k_sig_handle
+
+	/*
+	 * z_sig_handle() redirected the return path into the signal trampoline. The trampoline
+	 * chain clobbers the callee-saved registers per the ABI and k_sig_return() resumes the
+	 * interrupted context without unwinding, so capture them now: at this point they still
+	 * hold the interrupted context's values.
+	 */
+	get_cpu	x9
+	ldr	x9, [x9, #___cpu_t_current_OFFSET]
+	ldr	x10, =__thread_sig_user_x_OFFSET
+	add	x9, x9, x10
+	stp	x19, x20, [x9, #0]
+	stp	x21, x22, [x9, #16]
+	stp	x23, x24, [x9, #32]
+	stp	x25, x26, [x9, #48]
+	stp	x27, x28, [x9, #64]
+	b	skip_k_sig_handle
+
+z_sig_return_restore:
+	/* restore the callee-saved registers captured when the trampoline was entered */
+	get_cpu	x9
+	ldr	x9, [x9, #___cpu_t_current_OFFSET]
+	ldr	x10, =__thread_sig_user_x_OFFSET
+	add	x9, x9, x10
+	ldp	x19, x20, [x9, #0]
+	ldp	x21, x22, [x9, #16]
+	ldp	x23, x24, [x9, #32]
+	ldp	x25, x26, [x9, #48]
+	ldp	x27, x28, [x9, #64]
+
+skip_k_sig_handle:
+#endif
+
 	/* Return from exception */
 	b	z_arm64_exit_exc
