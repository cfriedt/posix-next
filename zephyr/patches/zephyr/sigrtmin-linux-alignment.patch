diff --git a/lib/libc/newlib/include/signal.h b/lib/libc/newlib/include/signal.h
index 7601ed05827..e558154c003 100644
--- a/lib/libc/newlib/include/signal.h
+++ b/lib/libc/newlib/include/signal.h
@@ -11,10 +11,17 @@

 #if defined(_POSIX_C_SOURCE) || defined(__DOXYGEN__)

-#define SIGRTMIN 32
+/*
+ * Newlib's <signal.h> defines SIGRTMIN as 32. Match Linux/glibc NPTL layout:
+ * reserve 32 (cancel) and 33, with application RT signals from 34.
+ */
+#undef SIGRTMIN
+#define SIGRTMIN 34
 #if defined(_POSIX_REALTIME_SIGNALS) || defined(__DOXYGEN__)
+#undef SIGRTMAX
 #define SIGRTMAX (SIGRTMIN + CONFIG_POSIX_RTSIG_MAX)
 #else
+#undef SIGRTMAX
 #define SIGRTMAX SIGRTMIN
 #endif

