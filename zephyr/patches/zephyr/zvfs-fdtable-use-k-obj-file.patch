diff --git a/lib/os/zvfs/zvfs_close.c b/lib/os/zvfs/zvfs_close.c
new file mode 100644
index 00000000000..86d1a4bbb02
--- /dev/null
+++ b/lib/os/zvfs/zvfs_close.c
@@ -0,0 +1,50 @@
+/*
+ * SPDX-FileCopyrightText: Copyright The Zephyr Project Contributors
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include <zephyr/sys/fdtable.h>
+#include <zephyr/sys/internal/fdtable_priv.h>
+#include <zephyr/sys/zvfs_libc.h>
+#include <zephyr/internal/syscall_handler.h>
+
+int z_impl_zvfs_close(int fd)
+{
+	int res = 0;
+	struct fd_entry *entry = zvfs_fd_entry_get(fd);
+
+	if (entry == NULL) {
+		return -1;
+	}
+
+	(void)k_mutex_lock(&entry->lock, K_FOREVER);
+	if (entry->vtable->close != NULL) {
+		if (entry->mode & ZVFS_MODE_IFSOCK) {
+			res = entry->vtable->close2(entry->obj, fd);
+		} else {
+			res = entry->vtable->close(entry->obj);
+		}
+	}
+	k_mutex_unlock(&entry->lock);
+
+#if defined(CONFIG_ZVFS_LIBC_FILE)
+	zvfs_libc_file_free(zvfs_libc_file_from_fd(fd));
+#endif
+
+	zvfs_free_fd(fd);
+
+	return res;
+}
+
+#ifdef CONFIG_USERSPACE
+static int z_vrfy_zvfs_close(int fd)
+{
+	if (zvfs_fd_syscall_verify(fd) == NULL) {
+		return -1;
+	}
+
+	return z_impl_zvfs_close(fd);
+}
+
+#include <zephyr/syscalls/zvfs_close_mrsh.c>
+#endif /* CONFIG_USERSPACE */
diff --git a/lib/os/zvfs/zvfs_fcntl.c b/lib/os/zvfs/zvfs_fcntl.c
new file mode 100644
index 00000000000..465629a1fc4
--- /dev/null
+++ b/lib/os/zvfs/zvfs_fcntl.c
@@ -0,0 +1,31 @@
+/*
+ * SPDX-FileCopyrightText: Copyright The Zephyr Project Contributors
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include <stdarg.h>
+
+#include <zephyr/sys/fdtable.h>
+#include <zephyr/sys/internal/fdtable_priv.h>
+
+int zvfs_fcntl(int fd, int cmd, va_list args)
+{
+	struct fd_entry *entry = zvfs_fd_entry_get(fd);
+
+	if (entry == NULL) {
+		return -1;
+	}
+
+	return entry->vtable->ioctl(entry->obj, cmd, args);
+}
+
+int zvfs_ioctl(int fd, unsigned long request, va_list args)
+{
+	struct fd_entry *entry = zvfs_fd_entry_get(fd);
+
+	if (entry == NULL) {
+		return -1;
+	}
+
+	return entry->vtable->ioctl(entry->obj, request, args);
+}
