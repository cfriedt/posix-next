 #define F_DUPFD 0
-#define F_GETFL 3
-#define F_SETFL 4
+#if defined(F_GETFL) && F_GETFL != ZVFS_F_GETFL
+#undef F_GETFL
+#endif
+#ifndef F_GETFL
