diff --git a/subsys/net/ip/Kconfig b/subsys/net/ip/Kconfig
index 322340a916c..ab5db42d6c0 100644
--- a/subsys/net/ip/Kconfig
+++ b/subsys/net/ip/Kconfig
@@ -10,16 +10,13 @@ menu "IP stack"
 
 config NET_NAMESPACE_COMPAT_MODE
 	bool "Network namespace compatibility mode"
-	# Disable the compatibility mode for network tests. But if the tests
-	# uses POSIX APIs, then currently the compat mode is needed.
-	depends on !NET_TEST || POSIX_API
 	default y
 	help
-	  The networking APIs and code is now namespaced i.e., relevant network
-	  APIs now have either net_, NET_ or ZSOCK_ prefixes. This avoids
-	  circular dependency against a Posix subsystem which might define
-	  duplicate symbols. The compatibility mode will be deprecated in the
-	  future and eventually removed.
+	  The networking APIs and code are namespaced, i.e. the relevant network
+	  APIs have net_, NET_ or ZSOCK_ prefixes. When enabled, this option also
+	  provides the well-known unprefixed spellings of Zephyr's non-standard,
+	  system-dependent networking constants (for example AF_PACKET,
+	  IPPROTO_IGMP, SO_PRIORITY, CAN_RAW, ARPHRD_ETHER).
 
 # Hidden option enabled whenever an IP stack is available.
 config NET_IP
