diff --git a/arch/x86/core/ia32/signal_trampoline.S b/arch/x86/core/ia32/signal_trampoline.S
new file mode 100644
index 00000000000..2ba458ca781
--- /dev/null
+++ b/arch/x86/core/ia32/signal_trampoline.S
@@ -0,0 +1,26 @@
+/*
+ * Copyright (c) 2026, Friedt Professional Engineering Services, Inc.
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include <zephyr/toolchain.h>
+
+GTEXT(arch_sig_trampoline)
+
+/*
+ * Small arch trampoline with explicit CFI so unwinding can traverse signal
+ * delivery into user code.
+ */
+SECTION_FUNC(text, arch_sig_trampoline)
+pushl %ebp
+.cfi_startproc
+.cfi_def_cfa_offset 8
+.cfi_offset %ebp, -8
+movl %esp, %ebp
+.cfi_def_cfa_register %ebp
+call z_sig_trampoline
+leave
+.cfi_def_cfa %esp, 4
+ret
+.cfi_endproc
