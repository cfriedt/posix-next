 LOG_MODULE_DECLARE(os, CONFIG_KERNEL_LOG_LEVEL);
@@ -1314,6 +1315,12 @@ static ALWAYS_INLINE void halt_thread(struct k_thread *thread, uint8_t new_state
 		k_thread_abort_cleanup(thread);
