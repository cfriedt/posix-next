diff --git a/kernel/timeout.c b/kernel/timeout.c
index ef470ccc6a0..205c368ebb5 100644
--- a/kernel/timeout.c
+++ b/kernel/timeout.c
@@ -42,6 +42,10 @@ static struct _timeout *next(struct _timeout *t)

 static void remove_timeout(struct _timeout *t)
 {
+	if (!sys_dnode_is_linked(&t->node)) {
+		return;
+	}
+
 	if (next(t) != NULL) {
 		next(t)->dticks += t->dticks;
 	}
