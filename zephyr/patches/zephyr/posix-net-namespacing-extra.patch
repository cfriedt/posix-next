+static inline void posix_sockaddr_in_from_zsock(const struct zsock_sockaddr_in *z,
+						struct sockaddr_in *p)
+{
+	memset(p, 0, sizeof(*p));
+	p->sin_family = AF_INET;
+	p->sin_port = z->sin_port;
+	p->sin_addr.s_addr = z->sin_addr.s_addr;
+}
+
+static inline void posix_sockaddr_in6_from_zsock(const struct zsock_sockaddr_in6 *z,
+						 struct sockaddr_in6 *p)
+{
+	memset(p, 0, sizeof(*p));
+	p->sin6_family = AF_INET6;
+	p->sin6_port = z->sin6_port;
+	memcpy(&p->sin6_addr, &z->sin6_addr, sizeof(p->sin6_addr));
+	p->sin6_scope_id = z->sin6_scope_id;
+}
+#endif
