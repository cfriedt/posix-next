/**
 * @defgroup posix_option_thread_attr_stacksize _POSIX_THREAD_ATTR_STACKSIZE
 * @brief POSIX Thread Stack Size Attribute option.
 */

/**
 * @defgroup posix_option_thread_cputime _POSIX_THREAD_CPUTIME
 * @brief POSIX Thread CPU-Time Clocks option.
 */

/**
 * @defgroup posix_option_thread_prio_inherit _POSIX_THREAD_PRIO_INHERIT
 * @brief POSIX Thread Priority Inheritance option.
 */

/**
 * @defgroup posix_option_thread_prio_protect _POSIX_THREAD_PRIO_PROTECT
 * @brief POSIX Thread Priority Protection option.
 */

/**
 * @defgroup posix_option_thread_priority_scheduling _POSIX_THREAD_PRIORITY_SCHEDULING
 * @brief POSIX Thread Priority Scheduling option.
 */

/**
 * @defgroup posix_option_thread_process_shared _POSIX_THREAD_PROCESS_SHARED
 * @brief POSIX Thread Process-Shared Synchronization option (placeholder).
 * @see https://pubs.opengroup.org/onlinepubs/9699919799/xrat/V4_subprofiles.html
 * @see https://pubs.opengroup.org/onlinepubs/9699919799/xrat/V4_subprofiles.html
 */

/**
 * @defgroup posix_option_timeouts _POSIX_TIMEOUTS
 * @brief POSIX feature-test macro for timed blocking APIs (not a Zephyr Option Group).
 *
