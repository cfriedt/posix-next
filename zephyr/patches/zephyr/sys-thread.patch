+struct dyn_cb_data {
+	k_tid_t tid;
+	k_thread_stack_t *stack;
+};
+
+static void dyn_cb(const struct k_thread *thread, void *user_data)
+{
+	struct dyn_cb_data *const data = (struct dyn_cb_data *)user_data;
+
+	if (data->stack == (k_thread_stack_t *)thread->stack_info.start) {
+		__ASSERT(data->tid == NULL, "stack %p is associated with more than one thread!",
+			 (void *)thread->stack_info.start);
+		data->tid = (k_tid_t)thread;
+	}
+}
+
+int z_impl_sys_thread_stack_alloc(k_thread_stack_t **stack, uint32_t *stack_size,
+				  uint32_t guard_size, uint32_t flags)
+{
+	ARG_UNUSED(stack_size);
+	ARG_UNUSED(guard_size);
+	ARG_UNUSED(flags);
+
+	if (CONFIG_SYS_THREAD_STACK_MAX == 0) {
+		LOG_WRN_ONCE("%s pool is disabled", heap_obj_str(K_OBJ_THREAD_STACK_ELEMENT));
+		return -ENOTSUP;
+	}
+
+	if ((*stack_size > CONFIG_SYS_THREAD_STACK_SIZE) &&
+	    (CONFIG_SYS_THREAD_STACK_MAX == SYS_THREAD_STACK_MIN)) {
+		/* If the pool is not configured to allow allocations from heap or anonymous memory
+		 * then the request cannot be satisfied */
+		LOG_WRN_ONCE("%s of size %u exceeds CONFIG_SYS_THREAD_STACK_SIZE (%u)",
+			     heap_obj_str(K_OBJ_THREAD_STACK_ELEMENT), *stack_size,
+			     CONFIG_SYS_THREAD_STACK_SIZE);
+		return -ENOMEM;
+	}
+
+	int ret = -ENOMEM;
+	bool use_mem_map = false;
+
+	if (*stack_size < CONFIG_SYS_THREAD_STACK_SIZE) {
+		*stack_size = CONFIG_SYS_THREAD_STACK_SIZE;
+	}
+
+	K_SPINLOCK(&stack_pool_lock) {
+		if (*stack_size <= CONFIG_SYS_THREAD_STACK_SIZE) {
+			if (SYS_THREAD_STACK_MIN > 0) {
+				/* Try the guaranteed-static entries first */
+				ret = sys_elastipool_api_alloc_static(&stack_pool, (void **)stack,
+								      flags);
+				if (ret == 0) {
+					K_SPINLOCK_BREAK;
+				}
+			}
+			if (!IS_ENABLED(CONFIG_SYS_THREAD_STACK_ALLOC_ANON)) {
+				/* Non-MMU: heap via elastipool (handles both dyn and elastic cases)
+				 */
+				ret = sys_elastipool_alloc(&stack_pool, (void **)stack);
+				K_SPINLOCK_BREAK;
+			}
+			/* ALLOC_ANON: static pool empty/exhausted; fall through to k_mem_map below
+			 */
+		}
+
+		/* Oversized stacks, or normal-size on ALLOC_ANON after static pool exhausted */
+		if (IS_ENABLED(CONFIG_SYS_THREAD_STACK_ALLOC_HEAP)) {
+			*stack = heap_obj_allocator(NULL, *stack_size, K_OBJ_THREAD_STACK_ELEMENT,
+						    flags);
+			ret = (*stack == NULL) ? -ENOMEM : 0;
+		} else if (IS_ENABLED(CONFIG_MMU) &&
+			   IS_ENABLED(CONFIG_SYS_THREAD_STACK_ALLOC_ANON)) {
+			/* Temporarily increase the size of the stack pool to reserve the stack, so
+			 * that we can map a new page without holding the spinlock */
+			if (stack_pool.data->pool_size >= stack_pool.config->max_obj) {
+				ret = -ENOMEM;
+				K_SPINLOCK_BREAK;
+			}
+			++stack_pool.data->pool_size;
+			use_mem_map = true;
+			ret = 0;
+		} else {
+			__ASSERT(false, "Invalid CONFIG_SYS_THREAD_STACK_ALLOC");
+		}
+	}
+
+	if (ret < 0) {
+		return ret;
+	}
+
+	if (use_mem_map) {
+#ifdef CONFIG_MMU
+		__ASSERT_NO_MSG(IS_ENABLED(CONFIG_MMU));
+
+		uint32_t map_size = 0;
+
+		if (IS_ENABLED(CONFIG_USERSPACE) && ((flags & K_USER) != 0)) {
+			*stack = k_object_map_size(K_OBJ_THREAD_STACK_ELEMENT, *stack_size);
+		} else {
+			map_size = (uint32_t)ROUND_UP(K_KERNEL_STACK_LEN(*stack_size),
+						      CONFIG_MMU_PAGE_SIZE);
+			*stack = k_mem_map(map_size,
+					   K_MEM_PERM_RW | K_MEM_MAP_LOCK | K_MEM_MAP_UNINIT);
+		}
+		K_SPINLOCK(&stack_pool_lock) {
+			if (*stack == NULL) {
+				ret = -ENOMEM;
+				--stack_pool.data->pool_size;
+				K_SPINLOCK_BREAK;
+			}
+
+			if (sys_hashmap_insert(stack_pool.config->map, (uint64_t)(uintptr_t)*stack,
+					       (uint64_t)map_size, NULL) < 0) {
+				k_mem_unmap(*stack, map_size);
+				*stack = NULL;
+				ret = -ENOMEM;
+				--stack_pool.data->pool_size;
+				K_SPINLOCK_BREAK;
+			}
+
+			ret = 0;
+		}
+#endif
+	}
+
+	if (ret == 0 && IS_ENABLED(CONFIG_USERSPACE) && ((flags & K_USER) != 0)) {
+		k_object_access_grant(*stack, _current);
+	}
+
+	return ret;
+}
+
+#ifdef CONFIG_USERSPACE
+int z_vrfy_sys_thread_stack_alloc(k_thread_stack_t **stack, uint32_t *stack_size,
+				  uint32_t guard_size, uint32_t flags)
+{
+	K_OOPS(K_SYSCALL_MEMORY_WRITE(stack, sizeof(*stack)));
+	K_OOPS(K_SYSCALL_MEMORY_WRITE(stack_size, sizeof(*stack_size)));
+	return z_impl_sys_thread_stack_alloc(stack, stack_size, guard_size, flags);
+}
+#include <zephyr/syscalls/sys_thread_stack_alloc_mrsh.c>
+#endif /* CONFIG_USERSPACE */
+
+static bool is_thread_stack_in_use(k_thread_stack_t *stack)
+{
+	struct dyn_cb_data data = {.stack = stack};
+
+	/* verify no live thread is associated with this stack */
+	k_thread_foreach(dyn_cb, &data);
+	if (data.tid != NULL) {
+		if (!(z_is_thread_state_set(data.tid, _THREAD_DUMMY) ||
+		      z_is_thread_state_set(data.tid, _THREAD_DEAD))) {
+			return true;
+		}
+	}
+
+	return false;
+}
+
+int z_impl_sys_thread_stack_destroy(k_thread_stack_t *stack)
+{
+	if (CONFIG_SYS_THREAD_STACK_MAX == 0) {
+		LOG_WRN_ONCE("%s pool is disabled", heap_obj_str(K_OBJ_THREAD_STACK_ELEMENT));
+		return -ENOTSUP;
+	}
+
+	if (is_thread_stack_in_use(stack)) {
+		return -EBUSY;
+	}
+
+	int ret = -EINVAL;
+
+	K_SPINLOCK(&stack_pool_lock) {
+#ifdef CONFIG_SYS_THREAD_STACK_ALLOC_ANON
+		if (SYS_THREAD_STACK_MIN > 0) {
+			ret = sys_elastipool_api_free_static(&stack_pool, stack);
+			if (ret == 0) {
+				K_SPINLOCK_BREAK;
+			}
+		}
+
+		uint64_t map_size;
+
+		if (sys_hashmap_remove(stack_pool.config->map, (uint64_t)(uintptr_t)stack,
+				       &map_size)) {
+			k_mem_unmap(stack, (size_t)map_size);
+			--stack_pool.data->pool_size;
+			ret = 0;
+			K_SPINLOCK_BREAK;
+		}
+#else
+		ret = sys_elastipool_free(&stack_pool, stack);
+#endif
+	}
+
+	return ret;
+}
+
+#ifdef CONFIG_USERSPACE
+static inline int z_vrfy_sys_thread_stack_destroy(k_thread_stack_t *stack)
+{
+	/* stack object must have been initialised (i.e. used) and is now dead */
+	K_OOPS(K_SYSCALL_OBJ_NEVER_INIT(stack, K_OBJ_THREAD_STACK_ELEMENT));
+	return z_impl_sys_thread_stack_destroy(stack);
+}
+#include <zephyr/syscalls/sys_thread_stack_destroy_mrsh.c>
+#endif /* CONFIG_USERSPACE */
+
+static void sys_thread_recycle_work_handler(struct k_work *work)
+{
+	ARG_UNUSED(work);
+
+	K_SPINLOCK(&thread_pool_lock) {
+		sys_thread_recycle();
+	}
+}
+
+static int sys_thread_recycle_one(struct k_thread *thread)
+{
+	k_thread_stack_t *stack = sys_thread_stack_obj(thread);
+	int ret = 0;
+
+	if (sys_elastipool_check(&thread_pool, thread) == 0) {
+		ret = sys_elastipool_free(&thread_pool, thread);
+	}
+
+#ifdef CONFIG_SYS_THREAD_STACK_ALLOC_ANON
+	if (CONFIG_SYS_THREAD_STACK_MAX != 0) {
+		K_SPINLOCK(&stack_pool_lock) {
+			if (SYS_THREAD_STACK_MIN > 0 && stack != NULL) {
+				if (sys_elastipool_api_free_static(&stack_pool, stack) == 0) {
+					K_SPINLOCK_BREAK;
+				}
+			}
+
+			/* Hash map keys must match z_impl_sys_thread_stack_alloc(): the pointer
+			 * returned from k_mem_map(), not necessarily stack_info.start minus reserved.
+			 */
+			if (stack != NULL) {
+				uint64_t map_size_val;
+
+				if (sys_hashmap_remove(stack_pool.config->map, (uint64_t)(uintptr_t)stack,
+						       &map_size_val)) {
+					k_mem_unmap(stack, (size_t)map_size_val);
+					--stack_pool.data->pool_size;
+				}
+			}
+		}
+	}
+#else
+	if (sys_elastipool_check(&stack_pool, stack) == 0) {
+		(void)sys_elastipool_free(&stack_pool, stack);
+	}
+#endif
+
+	return ret;
+}
+
+__maybe_unused static void sys_thread_recycle(void)
+{
+	for (size_t i = 0, n = sys_dlist_len(&thread_pool_free_list); i < n; ++i) {
+		struct k_thread *th = CONTAINER_OF(sys_dlist_get(&thread_pool_free_list),
+						   struct k_thread, base.sys_thread_free_node);
+
+		if (!(z_is_thread_state_set(th, _THREAD_DUMMY) ||
+		      z_is_thread_state_set(th, _THREAD_DEAD))) {
+			LOG_DBG("Skipping tid %p since it is in use", th);
+			sys_dlist_append(&thread_pool_free_list, &th->base.sys_thread_free_node);
+			continue;
+		}
+
+		(void)sys_thread_recycle_one(th);
+	}
+}
+
+int z_impl_sys_thread_create(struct k_thread **th, k_thread_stack_t *stack, uint32_t stack_size,
+			     uint32_t guard_size, k_thread_entry_t entry, void *p1, void *p2,
+			     void *p3, int prio, uint32_t options)
+{
+	int ret = -ENOMEM;
+
+	K_SPINLOCK(&thread_pool_lock) {
+		if (IS_ENABLED(CONFIG_THREAD_DETACH)) {
+			sys_thread_recycle();
+		}
+		ret = sys_elastipool_alloc(&thread_pool, (void **)th);
+	}
+
+	if (ret < 0) {
+		return ret;
+	}
+
+	if (stack == NULL) {
+		ret = sys_thread_stack_alloc(&stack, &stack_size, guard_size, options);
+		if (ret < 0) {
+			K_SPINLOCK(&thread_pool_lock) {
+				(void)sys_elastipool_free(&thread_pool, *th);
+			}
+			return ret;
+		}
+		/* sys_thread_stack_alloc() normalizes stack_size up to at least
+		 * CONFIG_SYS_THREAD_STACK_SIZE; reflect that here so k_thread_create()
+		 * receives the correct usable size. */
+		if (stack_size < CONFIG_SYS_THREAD_STACK_SIZE) {
+			stack_size = CONFIG_SYS_THREAD_STACK_SIZE;
+		}
+	}
+
+#ifdef CONFIG_USERSPACE
+	if (k_is_in_user_syscall()) {
+		k_object_access_grant(stack, *th);
+
+		k_tid_t z_vrfy_k_thread_create(struct k_thread * new_thread,
+					       k_thread_stack_t * stack, size_t stack_size,
+					       k_thread_entry_t entry, void *p1, void *p2, void *p3,
+					       int prio, uint32_t options, k_timeout_t delay);
+
+		k_object_access_grant(*th, *th);
+		k_object_access_grant(*th, _current);
+		k_object_uninit(*th);
+		z_vrfy_k_thread_create(*th, stack, stack_size, entry, p1, p2, p3, prio, options,
+				       K_NO_WAIT);
+		return 0;
+	}
+#endif
+
+	k_thread_create(*th, stack, stack_size, entry, p1, p2, p3, prio, options, K_NO_WAIT);
+
+	return 0;
+}
+
+#ifdef CONFIG_USERSPACE
+int z_vrfy_sys_thread_create(struct k_thread **th, k_thread_stack_t *stack, uint32_t stack_size,
+			     uint32_t guard_size, k_thread_entry_t entry, void *p1, void *p2,
+			     void *p3, int prio, uint32_t options)
+{
+	K_OOPS(K_SYSCALL_MEMORY_WRITE(th, sizeof(*th)));
+
+	/* user threads may only create other user threads and also must inherit permissions */
+	options |= K_USER | K_INHERIT_PERMS;
+
+	/* Further verification is performed in z_vrfy_k_thread_create() */
+	return z_impl_sys_thread_create(th, stack, stack_size, guard_size, entry, p1, p2, p3, prio,
+					options);
+}
+#include <zephyr/syscalls/sys_thread_create_mrsh.c>
+#endif
+
+int z_impl_sys_thread_destroy(struct k_thread *th)
+{
+	if ((CONFIG_SYS_THREAD_STACK_MAX == 0) && (CONFIG_SYS_THREAD_THREAD_MAX == 0)) {
+		LOG_WRN_ONCE("%s and %s pool are disabled", heap_obj_str(K_OBJ_THREAD), heap_obj_str(K_OBJ_THREAD_STACK_ELEMENT));
+		return -ENOTSUP;
+	}
+
+	int ret = -EBUSY;
+	bool schedule_work = false;
+
+	K_SPINLOCK(&thread_pool_lock) {
+		if (th != _current) {
+			__ASSERT(z_is_thread_state_set(th, _THREAD_DUMMY) ||
+					 z_is_thread_state_set(th, _THREAD_DEAD),
+				 "invalid state %x for thread %p", th->base.thread_state, th);
+
+			ret = sys_thread_recycle_one(th);
+			K_SPINLOCK_BREAK;
+		}
+
+		if (IS_ENABLED(CONFIG_THREAD_DETACH)) {
+			sys_dlist_append(&thread_pool_free_list, &th->base.sys_thread_free_node);
+			schedule_work = true;
+			ret = 0;
+			K_SPINLOCK_BREAK;
+		}
+
+		__ASSERT(false, "Non-detached thread attempted to destroy itself");
+	}
+
+	if (schedule_work) {
+		return k_work_schedule(&sys_thread_recycle_work,
+				       K_MSEC(CONFIG_SYS_THREAD_RECYCLER_DELAY_MS));
+	}
+
+	return ret;
+}
+
+#ifdef CONFIG_USERSPACE
+int z_vrfy_sys_thread_destroy(struct k_thread *th)
+{
+	K_OOPS(K_SYSCALL_OBJ(th, K_OBJ_THREAD));
+	return z_impl_sys_thread_destroy(th);
+}
+#include <zephyr/syscalls/sys_thread_destroy_mrsh.c>
+#endif
+
+static inline const char *const heap_obj_str(enum k_objects otype)
+{
+	switch (otype) {
+	case K_OBJ_CONDVAR:
+		return "k_condvar";
+	case K_OBJ_MUTEX:
+		return "k_mutex";
+	case K_OBJ_THREAD_STACK_ELEMENT:
+		return "k_thread_stack_t";
+	case K_OBJ_THREAD:
+		return "k_thread";
+	default:
+		__ASSERT(false, "invalid object type %d", otype);
+	}
+
+	return "";
+}
+
+static void *heap_obj_allocator(void *obj, size_t size, enum k_objects otype, uint32_t flags)
+{
+	if (obj == NULL) {
+		/* allocate an object */
+
+		if (IS_ENABLED(CONFIG_DYNAMIC_OBJECTS)) {
+			switch (otype) {
+			case K_OBJ_CONDVAR:
+			case K_OBJ_MUTEX:
+			case K_OBJ_THREAD:
+				return k_object_alloc(otype);
+			case K_OBJ_THREAD_STACK_ELEMENT:
+#ifdef CONFIG_USERSPACE
+				if (k_is_in_user_syscall() || ((flags & K_USER) != 0)) {
+					return k_object_alloc_size(K_OBJ_THREAD_STACK_ELEMENT,
+								   size);
+				} else
+#endif
+				{
+					return z_thread_aligned_alloc(Z_KERNEL_STACK_OBJ_ALIGN,
+								      K_KERNEL_STACK_LEN(size));
+				}
+			default:
+				__ASSERT(false, "invalid object type %d", otype);
+				return NULL;
+			}
+		}
+
+		if (IS_ENABLED(CONFIG_USERSPACE) && k_is_user_context()) {
+			LOG_WRN_ONCE("CONFIG_DYNAMIC_OBJECTS is not enabled");
+			return NULL;
+		}
+
+		size_t align;
+
+		switch (otype) {
+		case K_OBJ_CONDVAR:
+			size = sizeof(struct k_condvar);
+			align = __alignof(struct k_condvar);
+			break;
+		case K_OBJ_MUTEX:
+			size = sizeof(struct k_mutex);
+			align = __alignof(struct k_mutex);
+			break;
+		case K_OBJ_THREAD:
+			size = sizeof(struct k_thread);
+			align = __alignof(struct k_thread);
+			break;
+		case K_OBJ_THREAD_STACK_ELEMENT:
+			size = K_KERNEL_STACK_LEN(size);
+			align = Z_KERNEL_STACK_OBJ_ALIGN;
+			break;
+		default:
+			__ASSERT(false, "invalid object type %d", otype);
+			return NULL;
+		}
+
+		return z_thread_aligned_alloc(align, size);
+	}
+
+	/* deallocate an object */
+	__ASSERT(size == 0, "freeing object with non-zero size");
+
+#ifdef CONFIG_USERSPACE
+	if (k_object_find(obj)) {
+		k_object_free(obj);
+	} else {
+		k_free((void *)obj);
+	}
+#else
+	k_free((void *)obj);
+#endif /* CONFIG_USERSPACE */
+
+	return NULL;
+}
+
+static k_thread_stack_t *sys_thread_stack_obj(struct k_thread *thread)
+{
+#ifdef CONFIG_USERSPACE
+	if (sys_elastipool_check(&stack_pool, thread->stack_obj) == 0) {
+		return thread->stack_obj;
+	}
+
+	return NULL;
+#else
+	k_thread_stack_t *stack;
+
+#ifdef CONFIG_THREAD_STACK_MEM_MAPPED
+	void *mapped_base = (void *)((char *)thread->stack_info.start - K_KERNEL_STACK_RESERVED);
+	uintptr_t phys;
+
+	if (arch_page_phys_get(mapped_base, &phys) == 0) {
+		stack = (k_thread_stack_t *)phys;
+		if (sys_elastipool_check(&stack_pool, stack) == 0) {
+			return stack;
+		}
+	}
+
+	if (thread->stack_info.mapped.addr != NULL) {
+		if (arch_page_phys_get(thread->stack_info.mapped.addr, &phys) == 0) {
+			stack = (k_thread_stack_t *)phys;
+			if (sys_elastipool_check(&stack_pool, stack) == 0) {
+				return stack;
+			}
+		}
+	}
+#endif
+
+	/* Try common stack object base derivations used across architectures. */
+	stack = (k_thread_stack_t *)((char *)thread->stack_info.start - K_KERNEL_STACK_RESERVED);
+	if (sys_elastipool_check(&stack_pool, stack) == 0) {
+		return stack;
+	}
+
+	stack = (k_thread_stack_t *)thread->stack_info.start;
+	if (sys_elastipool_check(&stack_pool, stack) == 0) {
+		return stack;
+	}
+
+	if (thread->stack_info.delta > 0U) {
+		stack = (k_thread_stack_t *)((char *)thread->stack_info.start - K_KERNEL_STACK_RESERVED -
+					     thread->stack_info.delta);
+		if (sys_elastipool_check(&stack_pool, stack) == 0) {
+			return stack;
+		}
+
+		stack = (k_thread_stack_t *)((char *)thread->stack_info.start -
+					     thread->stack_info.delta);
+		if (sys_elastipool_check(&stack_pool, stack) == 0) {
+			return stack;
+		}
+	}
+
+	return NULL;
+#endif
+}
+
+#ifdef CONFIG_ZTEST
+#include <zephyr/ztest.h>
+static bool print_1pool_stats(const struct sys_elastipool *pool, const char *const name)
+{
+	if (pool->data->pool_size == 0) {
+		return false;
+	}
+	TC_PRINT("%s pool usage: %zu/%zu\n", name, pool->data->pool_size, pool->config->max_obj);
+	return true;
+}
+
+static void print_stats(const struct ztest_unit_test *test, void *data)
+{
+	ARG_UNUSED(test);
+	ARG_UNUSED(data);
+
+	bool leak = false;
+	int type[] = {K_OBJ_CONDVAR, K_OBJ_MUTEX, K_OBJ_THREAD_STACK_ELEMENT, K_OBJ_THREAD};
+	const struct sys_elastipool *const pool[] = {&cond_pool, &mutex_pool, &stack_pool,
+						     &thread_pool};
+
+	if (IS_ENABLED(CONFIG_THREAD_DETACH)) {
+		/* Drain pending recycled objects to avoid false positives in leak checks. */
+		K_SPINLOCK(&thread_pool_lock) {
+			sys_thread_recycle();
+		}
+	}
+
+	ARRAY_FOR_EACH(type, i) {
+		leak = print_1pool_stats(pool[i], heap_obj_str(type[i])) || leak;
+	}
+
+	/* This will assert if any tests leak objects */
+	__ASSERT(!leak, "object pool leak detected");
+}
+
+ZTEST_RULE(sys_thread_rule, NULL, print_stats);
+#endif /* CONFIG_ZTEST */
